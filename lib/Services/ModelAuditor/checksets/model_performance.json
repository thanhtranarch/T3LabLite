{
  "name": "Model Performance Check",
  "version": "1.0",
  "author": "DQT",
  "description": "Check model health and performance metrics - file size, warnings, CAD imports, In-Place families, groups, etc.",
  "created": "",
  "modified": "",
  "rules": [
    {
      "id": "MP_001",
      "name": "File Size",
      "category": "Model Performance",
      "description": "Check model file size. Large files slow down performance.",
      "type": "file_size",
      "severity": "warning",
      "enabled": true,
      "params": {
        "max_size_mb": 300
      }
    },
    {
      "id": "MP_002",
      "name": "Warning Count",
      "category": "Model Performance",
      "description": "Check total Revit warnings. High count indicates model issues.",
      "type": "warning_count",
      "severity": "warning",
      "enabled": true,
      "params": {
        "max_count": 100
      }
    },
    {
      "id": "MP_003",
      "name": "Total Element Count",
      "category": "Model Performance",
      "description": "Check total number of elements in model",
      "type": "element_count",
      "severity": "info",
      "enabled": true,
      "params": {
        "max_count": 500000
      }
    },
    {
      "id": "MP_004",
      "name": "CAD Imports",
      "category": "Model Performance",
      "description": "Detect imported CAD files. These should be removed before submission.",
      "type": "cad_import_check",
      "severity": "error",
      "enabled": true,
      "params": {
        "max_count": 0,
        "check_type": "imported"
      }
    },
    {
      "id": "MP_005",
      "name": "CAD Links",
      "category": "Model Performance",
      "description": "Check linked CAD files count",
      "type": "cad_import_check",
      "severity": "warning",
      "enabled": true,
      "params": {
        "max_count": 10,
        "check_type": "linked"
      }
    },
    {
      "id": "MP_006",
      "name": "In-Place Families",
      "category": "Model Performance",
      "description": "Detect In-Place families. Should be minimized for performance.",
      "type": "inplace_family_check",
      "severity": "warning",
      "enabled": true,
      "params": {
        "max_count": 5
      }
    },
    {
      "id": "MP_007",
      "name": "RVT Links",
      "category": "Model Performance",
      "description": "Check Revit link count and loaded status",
      "type": "rvt_link_check",
      "severity": "warning",
      "enabled": true,
      "params": {
        "max_count": 20,
        "check_loaded": true
      }
    },
    {
      "id": "MP_008",
      "name": "Group Types",
      "category": "Model Performance",
      "description": "Check model/detail group types. Too many groups impact performance.",
      "type": "group_check",
      "severity": "warning",
      "enabled": true,
      "params": {
        "max_count": 20
      }
    },
    {
      "id": "MP_009",
      "name": "Line Patterns",
      "category": "Model Performance",
      "description": "Check line pattern count. Excessive patterns from CAD imports.",
      "type": "line_pattern_check",
      "severity": "info",
      "enabled": true,
      "params": {
        "max_count": 50
      }
    },
    {
      "id": "MP_010",
      "name": "Unplaced Rooms",
      "category": "Element Quality",
      "description": "Detect unplaced or unbounded rooms",
      "type": "unplaced_rooms",
      "severity": "warning",
      "enabled": true,
      "params": {
        "max_count": 0
      }
    },
    {
      "id": "MP_011",
      "name": "Rooms with Small Area",
      "category": "Element Quality",
      "description": "Detect rooms with very small area (possible errors)",
      "type": "room_area_check",
      "severity": "warning",
      "enabled": true,
      "params": {
        "min_area_sqm": 0.5
      }
    },
    {
      "id": "MP_012",
      "name": "Detail Lines Count",
      "category": "Model Performance",
      "description": "Check total detail lines. Excessive detail lines impact performance.",
      "type": "category_count",
      "severity": "warning",
      "enabled": true,
      "params": {
        "category": "Detail Lines",
        "built_in_category": "OST_Lines",
        "max_count": 10000
      }
    },
    {
      "id": "MP_013",
      "name": "Reference Planes",
      "category": "Model Performance",
      "description": "Check reference plane count",
      "type": "category_count",
      "severity": "info",
      "enabled": true,
      "params": {
        "category": "Reference Planes",
        "built_in_category": "OST_CLines",
        "max_count": 200
      }
    },
    {
      "id": "MP_014",
      "name": "Design Options",
      "category": "Model Performance",
      "description": "Design Options should be resolved before submission",
      "type": "count_check",
      "severity": "error",
      "enabled": true,
      "params": {
        "target": "design_options",
        "max_count": 0,
        "message_over": "Resolve Design Options before submission"
      }
    }
  ]
}
