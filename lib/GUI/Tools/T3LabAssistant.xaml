<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="T3Lab Assistant"
       Width="560" Height="720"
       MinWidth="480" MinHeight="580"
       WindowStartupLocation="CenterScreen"
       ResizeMode="CanResizeWithGrip"
       ShowInTaskbar="True"
       Background="#E4E4E7"
       FontFamily="Hanken Grotesk">

        <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                       ResizeBorderThickness="5"
                       GlassFrameThickness="0"
                       CornerRadius="8"
                       UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ═══ T3LAB SHARED STYLES v2 — AUTO-SYNCED, DO NOT EDIT (edit lib/GUI/Resources/WPF_styles.xaml, then run dev/sync_wpf_styles.py) ═══ -->
        <!-- Central Color Brushes (Lumina / T3Lab Standard System) -->
        <SolidColorBrush x:Key="T3PrimaryInkBrush" Color="#18181B"/>
        <SolidColorBrush x:Key="T3PrimaryTextBrush" Color="#27272A"/>
        <SolidColorBrush x:Key="T3SecondaryTextBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="T3TertiaryTextBrush" Color="#71717A"/>
        <SolidColorBrush x:Key="T3DisabledBorderBrush" Color="#9A9AA2"/>
        <SolidColorBrush x:Key="T3MainAppBgBrush" Color="#E4E4E7"/>
        <SolidColorBrush x:Key="T3ComponentBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="T3InputFieldBgBrush" Color="#F4F4F6"/>
        
        <!-- Semantic & Status Brushes -->
        <SolidColorBrush x:Key="T3SuccessBgBrush" Color="#EAF8F0"/>
        <SolidColorBrush x:Key="T3SuccessTextBrush" Color="#157038"/>
        <SolidColorBrush x:Key="T3SuccessBorderBrush" Color="#09734B"/>
        <SolidColorBrush x:Key="T3SuccessAccentBrush" Color="#0B8A5A"/>
        
        <SolidColorBrush x:Key="T3WarningBgBrush" Color="#FFF6E6"/>
        <SolidColorBrush x:Key="T3WarningTextBrush" Color="#8A6308"/>
        <SolidColorBrush x:Key="T3WarningAccentBrush" Color="#F5CE5A"/>
        
        <SolidColorBrush x:Key="T3DangerBgBrush" Color="#FDECEC"/>
        <SolidColorBrush x:Key="T3DangerTextBrush" Color="#D23B3B"/>
        <SolidColorBrush x:Key="T3DangerAccentBrush" Color="#F87171"/>
        
        <SolidColorBrush x:Key="T3ProgressActionBrush" Color="#C2410C"/>

        <!-- TERTIARY BUTTON - soft gray background, dark text -->
        <Style x:Key="TertiaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#ECECEF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E2E6"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#ECECEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sleek Modern ComboBox -->
        <Style x:Key="T3ComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Content -->
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                                      
                                    <!-- Toggle Button (Arrow) -->
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    
                                    <!-- Arrow Icon -->
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            
                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="true"
                                   IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="13"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Toggle Switch Style (CheckBox) -->
        <Style x:Key="T3ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="0" 
                                              Focusable="False" 
                                              HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                              
                            <!-- Toggle Track -->
                            <Border x:Name="toggleTrack" 
                                    Grid.Column="1"
                                    Width="42" Height="24"
                                    Background="#DCDCE2"
                                    CornerRadius="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <!-- Toggle Knob -->
                                <Ellipse x:Name="toggleKnob"
                                         Width="20" Height="20"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="2,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="1" Direction="270" Color="Black" Opacity="0.15" BlurRadius="2"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#18181B"/>
                                <Setter TargetName="toggleKnob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="toggleKnob" Property="Fill" Value="#9A9AA2"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Slider -->
        <Style x:Key="T3Slider" TargetType="Slider">
            <Setter Property="Background" Value="#E4E4E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Border x:Name="TrackBackground"
                                    Grid.Row="1"
                                    Height="6"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"/>
                                    
                            <!-- Track Fill and Thumb -->
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="#C2410C" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="18" Height="18"
                                                         Fill="White"
                                                         Stroke="#C2410C"
                                                         StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="2" Direction="270" Color="#C2410C" Opacity="0.3" BlurRadius="4"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field -->
        <Style x:Key="T3InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Modern GroupBox Card -->
        <Style x:Key="T3PremiumCard" TargetType="GroupBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Card Header -->
                                <Border Grid.Row="0" 
                                        Background="#FFFFFF"
                                        Padding="16,12"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter ContentSource="Header"
                                                      TextBlock.FontSize="14"
                                                      TextBlock.FontWeight="Bold"
                                                      TextBlock.Foreground="#18181B"
                                                      TextBlock.FontFamily="Hanken Grotesk"/>
                                </Border>
                                <!-- Card Content -->
                                <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Top Navigation Tab Style -->
        <Style x:Key="T3TopNavTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON - solid deep slate, white text -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#18181B"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SECONDARY BUTTON - white background, border and text slate -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#DEDEE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFB"/>
                    <Setter Property="BorderBrush" Value="#CFCFD5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="BorderBrush" Value="#E6E6EA"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GHOST BUTTON -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#52525B"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                    <Setter Property="Foreground" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E2E2E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SUCCESS BUTTON -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0B8A5A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#09734B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0B8A5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#D23B3B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F87171"/>
                    <Setter Property="Foreground" Value="#1F1F23"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ACCENT BUTTON -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#18181B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Icon Button Style -->
        <Style x:Key="T3SidebarButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F4F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- WINDOW CONTROL BUTTON -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#18181B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E4E4E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CLOSE BUTTON -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Premium CheckBox Style -->
        <Style x:Key="T3CheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBoxBorder" 
                                    Grid.Column="0"
                                    Width="18" Height="18"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="1.5"
                                    Background="White"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Path x:Name="optionMark" 
                                      Data="M4,9 L8,13 L14,5" 
                                      Stroke="White" 
                                      StrokeThickness="2" 
                                      StrokeStartLineCap="Round" 
                                      StrokeEndLineCap="Round" 
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#18181B"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="optionMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium RadioButton Style -->
        <Style x:Key="T3RadioButton" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="radioBorder" 
                                    Grid.Column="0"
                                    Width="20" Height="20"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="2"
                                    Background="White"
                                    CornerRadius="10"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Ellipse x:Name="radioDot"
                                         Width="9" Height="9"
                                         Fill="#18181B"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="radioDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="radioBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Scrollbar Styling -->
        <Style TargetType="{x:Type Thumb}" x:Key="ScrollBarThumbStyle">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="thumbBorder" Background="#A1A1AA" CornerRadius="2" Margin="0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#71717A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="true"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="false"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="4"/>
                    <Setter Property="Height" Value="Auto"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- SIDEBAR TOGGLE BUTTON (for icon-only sidebar filter/nav) -->
        <Style x:Key="T3SidebarToggle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#18181B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sleek Modern ComboBox Small -->
        <Style x:Key="T3ComboBoxSmall" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="10" Height="10"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                    AllowsTransparency="true"
                                    IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    Placement="Bottom"
                                    PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern ComboBox Small ToggleButton -->
        <Style x:Key="T3ComboBoxSmallToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  IsHitTestVisible="False"/>
                                <Path Grid.Column="1"
                                      Data="M6 9 L12 15 L18 9"
                                      Stroke="#71717A"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="10" Height="10"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field Small -->
        <Style x:Key="T3InputFieldSmall" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ProgressBar Style (Lumina Standard) -->
        <Style x:Key="T3ProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#ECECEF"/>
            <Setter Property="Foreground" Value="#C2410C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="BackgroundBorder" Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Border x:Name="PART_Track" ClipToBounds="True" CornerRadius="4" Background="Transparent">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="4"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Queue Item ProgressBar Style with complete trigger -->
        <Style x:Key="QueueProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource T3ProgressBar}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Progress}" Value="100">
                    <Setter Property="Foreground" Value="#10B981"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ END T3LAB SHARED STYLES ═══ -->

        <!-- ── Send button style (pill corner radius matching input) ── -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#0F172A"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="18,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="0,20,20,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Cursor"     Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Attachment chip button ── -->
        <Style x:Key="AttachChipBtn" TargetType="Button">
            <Setter Property="Background"      Value="#F8FAFC"/>
            <Setter Property="Foreground"      Value="#1E293B"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon-only button (attach) ── -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    
    <Border BorderBrush="#A1A1AA" BorderThickness="1.5" CornerRadius="22" ClipToBounds="True" Background="#E4E4E7">
<Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- Header   -->
            <RowDefinition Height="1"/>    <!-- Separator -->
            <RowDefinition Height="*"/>    <!-- Chat area -->
            <RowDefinition Height="Auto"/> <!-- Input bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             HEADER — T3Lab badge + title
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <StackPanel Grid.Column="0" Orientation="Vertical"
                        Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                               Foreground="#0F172A" VerticalAlignment="Bottom"
                               Margin="0,0,6,3"/>
                    <TextBlock Text="Assistant" FontSize="18" FontWeight="Bold"
                               Foreground="#0F172A"/>
                    <!-- AI / LOCAL status badge -->
                    <Border x:Name="ai_status_badge"
                            CornerRadius="3" Padding="14,8"
                            Margin="8,2,0,0" VerticalAlignment="Center"
                            Visibility="Collapsed" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="ai_status_text"
                                   FontSize="9" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>
                <Separator Height="1" Background="#E2E8F0" Margin="0,2,0,2"/>
                <TextBlock Text="Chatbox AI cho T3Lab Tools — Tiếng Việt &amp; English"
                           FontSize="10" Foreground="#64748B" FontStyle="Italic"/>
            </StackPanel>

            <!-- Window control buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Top" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Undo -->
                <Button x:Name="btn_undo"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Hoàn tác (Undo)"
                        Click="undo_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="↶" FontSize="18" FontWeight="Bold" Foreground="#F59E0B"/>
                </Button>
                <!-- Reset -->
                <Button x:Name="btn_reset_chat"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Làm mới cuộc trò chuyện"
                        Click="reset_chat_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="↺" FontSize="15" FontWeight="Bold" Foreground="#64748B"/>
                </Button>
                <!-- Minimize -->
                <Button x:Name="btn_minimize"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Minimize" Click="minimize_clicked">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                </Button>
                <!-- Close -->
                <Button x:Name="btn_close"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close" Click="close_clicked">
                    <TextBlock x:Name="close_text" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Header separator -->
        <Border Grid.Row="1" Background="#E2E8F0"/>

        <!-- ═══════════════════════════════════════════════════════════
             CHAT AREA
        ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" x:Name="chat_scroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#F8FAFC"
                      Padding="16,12,16,8">
            <StackPanel x:Name="chat_history_panel" Margin="0,0,0,4">

                <!-- Welcome bubble (static, always shown) -->
                <Grid Margin="0,0,60,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- T3 Avatar -->
                    <Border Grid.Column="0" Width="34" Height="34"
                            CornerRadius="17" Background="#0F172A"
                            Margin="0,2,10,0" VerticalAlignment="Top">
                        <TextBlock Text="T3" FontSize="11" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Welcome message bubble -->
                    <Border Grid.Column="1" Background="White"
                            CornerRadius="3,10,10,10"
                            Padding="14,10"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="T3Lab Assistant" FontSize="10" FontWeight="Bold"
                                       Foreground="#0F172A" Margin="0,0,0,5"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#0F172A"
                                       LineHeight="20"
                                       Text="Xin chào! Tôi là T3Lab Assistant. Tôi có thể:"/>
                            <StackPanel Margin="0,6,0,0">
                                <TextBlock FontSize="12" Foreground="#64748B"
                                           Text="• Mở BatchOut và xuất sheet PDF/DWG/DWF..."/>
                                <TextBlock FontSize="12" Foreground="#64748B" Margin="0,3,0,0"
                                           Text="• Chạy ParaSync, Load Family, và các công cụ khác"/>
                                <TextBlock FontSize="12" Foreground="#64748B" Margin="0,3,0,0"
                                           Text="• Phân tích tài liệu PDF và hình ảnh đính kèm (RAG)"/>
                                <TextBlock FontSize="12" Foreground="#64748B" Margin="0,3,0,0"
                                           Text="• Trả lời câu hỏi về T3Lab và Revit"/>
                            </StackPanel>
                            <Separator Height="1" Background="#E2E8F0" Margin="0,8,0,6"/>
                            <TextBlock FontSize="11" Foreground="#94A3B8" FontStyle="Italic"
                                       Text="Nhập lệnh bằng Tiếng Việt hoặc English — Enter để gửi. 📎 để đính kèm PDF/ảnh."/>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════
             INPUT BAR & ACTION CENTER
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#F8FAFC"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="16,8,16,10">
            <StackPanel>

                <!-- ── Suggested Actions Panel ── -->
                <StackPanel x:Name="suggested_actions_container" Margin="0,0,0,8">
                    <TextBlock Text="Suggested Actions" FontSize="10" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="4,0,0,4"/>
                    <WrapPanel x:Name="suggested_actions_panel">
                        <!-- Chips will be added dynamically -->
                    </WrapPanel>
                </StackPanel>

                <!-- ── Attachment preview strip (hidden until files attached) ── -->
                <Border x:Name="attachment_preview_border"
                        Visibility="Collapsed"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="3"
                        Padding="8,6"
                        Margin="0,0,0,6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Đính kèm:" FontSize="10" FontWeight="Bold"
                                       Foreground="#1E293B" VerticalAlignment="Center"/>
                            <Button x:Name="btn_clear_attachments"
                                    Style="{StaticResource IconButton}"
                                    Click="clear_attachments_clicked"
                                    ToolTip="Xóa tất cả đính kèm"
                                    Margin="6,0,0,0"
                                    Padding="3,1">
                                <TextBlock Text="✕ Xóa tất cả" FontSize="9" Foreground="#EF4444"/>
                            </Button>
                        </StackPanel>
                        <WrapPanel x:Name="attachment_chips_panel"/>
                    </StackPanel>
                </Border>

                <!-- ── Input row ── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- Attach button -->
                        <ColumnDefinition Width="*"/>     <!-- Text input -->
                        <ColumnDefinition Width="Auto"/>  <!-- Send button -->
                    </Grid.ColumnDefinitions>

                    <!-- Attach button -->
                    <Button Grid.Column="0" x:Name="btn_attach"
                             Style="{StaticResource IconButton}"
                             Height="38" Width="38"
                             Click="attach_clicked"
                             ToolTip="Đính kèm hình ảnh hoặc PDF">
                        <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                    Foreground="#0F172A" VerticalAlignment="Center"
                                    HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Text input -->
                    <Border Grid.Column="1"
                            BorderBrush="#CBD5E1" BorderThickness="1,1,0,1"
                            CornerRadius="20,0,0,20" Background="White">
                        <TextBox x:Name="chat_input"
                                  Height="38"
                                  VerticalContentAlignment="Center"
                                  Padding="14,0"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  FontSize="13"
                                  Foreground="#0F172A"
                                  CaretBrush="#0F172A"
                                  ToolTip="Nhập lệnh Tiếng Việt hoặc English (Enter để gửi)"
                                  KeyDown="input_keydown"/>
                    </Border>

                    <!-- Send button -->
                    <Button Grid.Column="2" x:Name="send_button"
                             Height="38"
                             Style="{StaticResource SendButtonStyle}"
                             Padding="18,0"
                             Click="send_clicked"
                             ToolTip="Gửi (Enter)">

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Gửi" VerticalAlignment="Center" FontSize="13"/>
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                            VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>

                    </Button>
                </Grid>
            </StackPanel>
        </Border>
        <!-- Copyright added automatically -->
        <TextBlock Text="Â© Copyright by T3Lab" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,8" Foreground="#F59E0B" FontSize="11" IsHitTestVisible="False" Panel.ZIndex="999" Grid.RowSpan="99" Grid.ColumnSpan="99"/>
</Grid>

    </Border>

</Window>
