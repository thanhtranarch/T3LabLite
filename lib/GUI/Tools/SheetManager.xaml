<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="T3Lab — Sheet Manager"
        Height="730" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="#E4E4E7"
        FontFamily="Hanken Grotesk"
        FontSize="12"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="22"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ═══ T3LAB SHARED STYLES v2 — AUTO-SYNCED, DO NOT EDIT (edit lib/GUI/Resources/WPF_styles.xaml, then run dev/sync_wpf_styles.py) ═══ -->
        <!-- Central Color Brushes (Lumina / T3Lab Standard System) -->
        <SolidColorBrush x:Key="T3PrimaryInkBrush" Color="#18181B"/>
        <SolidColorBrush x:Key="T3PrimaryTextBrush" Color="#27272A"/>
        <SolidColorBrush x:Key="T3SecondaryTextBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="T3TertiaryTextBrush" Color="#71717A"/>
        <SolidColorBrush x:Key="T3DisabledBorderBrush" Color="#9A9AA2"/>
        <SolidColorBrush x:Key="T3MainAppBgBrush" Color="#E4E4E7"/>
        <SolidColorBrush x:Key="T3ComponentBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="T3InputFieldBgBrush" Color="#F4F4F6"/>
        
        <!-- Semantic & Status Brushes -->
        <SolidColorBrush x:Key="T3SuccessBgBrush" Color="#EAF8F0"/>
        <SolidColorBrush x:Key="T3SuccessTextBrush" Color="#157038"/>
        <SolidColorBrush x:Key="T3SuccessBorderBrush" Color="#09734B"/>
        <SolidColorBrush x:Key="T3SuccessAccentBrush" Color="#0B8A5A"/>
        
        <SolidColorBrush x:Key="T3WarningBgBrush" Color="#FFF6E6"/>
        <SolidColorBrush x:Key="T3WarningTextBrush" Color="#8A6308"/>
        <SolidColorBrush x:Key="T3WarningAccentBrush" Color="#F5CE5A"/>
        
        <SolidColorBrush x:Key="T3DangerBgBrush" Color="#FDECEC"/>
        <SolidColorBrush x:Key="T3DangerTextBrush" Color="#D23B3B"/>
        <SolidColorBrush x:Key="T3DangerAccentBrush" Color="#F87171"/>
        
        <SolidColorBrush x:Key="T3ProgressActionBrush" Color="#C2410C"/>

        <!-- TERTIARY BUTTON - soft gray background, dark text -->
        <Style x:Key="TertiaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#ECECEF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E2E6"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#ECECEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sleek Modern ComboBox -->
        <Style x:Key="T3ComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Content -->
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                                      
                                    <!-- Toggle Button (Arrow) -->
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    
                                    <!-- Arrow Icon -->
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            
                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="true"
                                   IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="13"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Toggle Switch Style (CheckBox) -->
        <Style x:Key="T3ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="0" 
                                              Focusable="False" 
                                              HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                              
                            <!-- Toggle Track -->
                            <Border x:Name="toggleTrack" 
                                    Grid.Column="1"
                                    Width="42" Height="24"
                                    Background="#DCDCE2"
                                    CornerRadius="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <!-- Toggle Knob -->
                                <Ellipse x:Name="toggleKnob"
                                         Width="20" Height="20"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="2,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="1" Direction="270" Color="Black" Opacity="0.15" BlurRadius="2"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#18181B"/>
                                <Setter TargetName="toggleKnob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="toggleKnob" Property="Fill" Value="#9A9AA2"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Slider -->
        <Style x:Key="T3Slider" TargetType="Slider">
            <Setter Property="Background" Value="#E4E4E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Border x:Name="TrackBackground"
                                    Grid.Row="1"
                                    Height="6"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"/>
                                    
                            <!-- Track Fill and Thumb -->
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="#C2410C" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="18" Height="18"
                                                         Fill="White"
                                                         Stroke="#C2410C"
                                                         StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="2" Direction="270" Color="#C2410C" Opacity="0.3" BlurRadius="4"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field -->
        <Style x:Key="T3InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Modern GroupBox Card -->
        <Style x:Key="T3PremiumCard" TargetType="GroupBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Card Header -->
                                <Border Grid.Row="0" 
                                        Background="#FFFFFF"
                                        Padding="16,12"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter ContentSource="Header"
                                                      TextBlock.FontSize="14"
                                                      TextBlock.FontWeight="Bold"
                                                      TextBlock.Foreground="#18181B"
                                                      TextBlock.FontFamily="Hanken Grotesk"/>
                                </Border>
                                <!-- Card Content -->
                                <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Top Navigation Tab Style -->
        <Style x:Key="T3TopNavTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON - solid deep slate, white text -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#18181B"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SECONDARY BUTTON - white background, border and text slate -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#DEDEE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFB"/>
                    <Setter Property="BorderBrush" Value="#CFCFD5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="BorderBrush" Value="#E6E6EA"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GHOST BUTTON -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#52525B"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                    <Setter Property="Foreground" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E2E2E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SUCCESS BUTTON -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0B8A5A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#09734B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0B8A5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#D23B3B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F87171"/>
                    <Setter Property="Foreground" Value="#1F1F23"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ACCENT BUTTON -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#18181B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Icon Button Style -->
        <Style x:Key="T3SidebarButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F4F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- WINDOW CONTROL BUTTON -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#18181B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E4E4E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CLOSE BUTTON -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Premium CheckBox Style -->
        <Style x:Key="T3CheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBoxBorder" 
                                    Grid.Column="0"
                                    Width="18" Height="18"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="1.5"
                                    Background="White"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Path x:Name="optionMark" 
                                      Data="M4,9 L8,13 L14,5" 
                                      Stroke="White" 
                                      StrokeThickness="2" 
                                      StrokeStartLineCap="Round" 
                                      StrokeEndLineCap="Round" 
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#18181B"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="optionMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium RadioButton Style -->
        <Style x:Key="T3RadioButton" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="radioBorder" 
                                    Grid.Column="0"
                                    Width="20" Height="20"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="2"
                                    Background="White"
                                    CornerRadius="10"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Ellipse x:Name="radioDot"
                                         Width="9" Height="9"
                                         Fill="#18181B"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="radioDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="radioBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Scrollbar Styling -->
        <Style TargetType="{x:Type Thumb}" x:Key="ScrollBarThumbStyle">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="thumbBorder" Background="#A1A1AA" CornerRadius="2" Margin="0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#71717A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="true"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="false"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="4"/>
                    <Setter Property="Height" Value="Auto"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- SIDEBAR TOGGLE BUTTON (for icon-only sidebar filter/nav) -->
        <Style x:Key="T3SidebarToggle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#18181B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sleek Modern ComboBox Small -->
        <Style x:Key="T3ComboBoxSmall" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="10" Height="10"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                    AllowsTransparency="true"
                                    IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    Placement="Bottom"
                                    PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern ComboBox Small ToggleButton -->
        <Style x:Key="T3ComboBoxSmallToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  IsHitTestVisible="False"/>
                                <Path Grid.Column="1"
                                      Data="M6 9 L12 15 L18 9"
                                      Stroke="#71717A"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="10" Height="10"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field Small -->
        <Style x:Key="T3InputFieldSmall" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ProgressBar Style (Lumina Standard) -->
        <Style x:Key="T3ProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#ECECEF"/>
            <Setter Property="Foreground" Value="#C2410C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="BackgroundBorder" Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Border x:Name="PART_Track" ClipToBounds="True" CornerRadius="4" Background="Transparent">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="4"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Queue Item ProgressBar Style with complete trigger -->
        <Style x:Key="QueueProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource T3ProgressBar}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Progress}" Value="100">
                    <Setter Property="Foreground" Value="#10B981"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Pill RadioButton Style -->
        <Style x:Key="TabPillRadioButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="TabPills"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E2E6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ END T3LAB SHARED STYLES ═══ -->

        <!-- Sidebar icon nav RadioButton -->
        <Style x:Key="T3SidebarIconNav" TargetType="RadioButton">
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#18181B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#A1A1AA" BorderThickness="1.5" CornerRadius="22" ClipToBounds="True" Background="#E4E4E7">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="66"/>  <!-- Sidebar icon rail -->
                <ColumnDefinition Width="*"/>   <!-- Main content -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>   <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content Area -->
                <RowDefinition Height="Auto"/> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- ═══ SIDEBAR (Column 0, spans all rows) ═══ -->
            <Border Grid.Column="0" Grid.RowSpan="3"
                    Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,0,1,0"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid Margin="0,12,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <Border Grid.Row="0" Width="42" Height="42" CornerRadius="13"
                            Background="White" BorderBrush="#DCDCE0" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Path Data="M12 4 L20 8 L12 12 L4 8 Z M4 12 L12 16 L20 12 M4 16 L12 20 L20 16"
                              Stroke="#18181B" StrokeThickness="1.8" StrokeLineJoin="Round"
                              Width="20" Height="20" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Nav: Sheets -->
                    <RadioButton Grid.Row="1" x:Name="nav_sheets"
                                 Style="{StaticResource T3SidebarIconNav}"
                                 IsChecked="True" GroupName="SheetNav"
                                 Margin="0,0,0,6" ToolTip="Sheets">
                        <Path Data="M2 3H18V6H2Z M2 9H14V12H2Z M2 15H18V18H2Z"
                              Width="18" Height="18" Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type RadioButton}}}"/>
                    </RadioButton>

                    <!-- Nav: Renumber -->
                    <RadioButton Grid.Row="2" x:Name="nav_renumber"
                                 Style="{StaticResource T3SidebarIconNav}"
                                 GroupName="SheetNav"
                                 Margin="0,0,0,6" ToolTip="Renumber">
                        <Path Data="M6 2V18M14 2V18M2 7H18M2 13H18"
                              Width="18" Height="18" Stretch="Uniform"
                              StrokeThickness="2"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type RadioButton}}}"
                              Fill="Transparent"/>
                    </RadioButton>
                </Grid>
            </Border>

            <!-- ═══ HEADER (Row 0, Column 1) ═══ -->
            <Border Grid.Row="0" Grid.Column="1" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title & Subtitle -->
                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="22,0,0,0" VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="Sheet Manager" FontSize="15" FontWeight="Bold" Foreground="#18181B"/>
                        <TextBlock Text="Manage sheets, sets, and renumbering" FontSize="12.5" Foreground="#71717A" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Window Controls (Chrome) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,16,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="btn_minimize" Style="{StaticResource WinCtrlButton}"
                                ToolTip="Minimize"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                        <Button x:Name="btn_maximize" Style="{StaticResource WinCtrlButton}"
                                ToolTip="Maximize"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                        <Button x:Name="btn_close" Style="{StaticResource CloseButton}"
                                ToolTip="Close"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>

                    <Border Height="1" VerticalAlignment="Bottom" Background="#DCDCE0" Grid.ColumnSpan="2"/>
                </Grid>
            </Border>

            <!-- ═══ CONTENT (Row 1, Column 1) ═══ -->
            <TabControl x:Name="tab_control" Grid.Row="1" Grid.Column="1" BorderThickness="0" Background="Transparent" Margin="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/> <!-- Hides Tab Headers -->
                    </Style>
                </TabControl.Resources>

                <!-- TAB 1: SHEETS LIST -->
                <TabItem x:Name="tab_sheets_item">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Cards Summary -->
                            <RowDefinition Height="*"/>    <!-- DataGrid & Filters -->
                            <RowDefinition Height="Auto"/> <!-- Actions Footer -->
                        </Grid.RowDefinitions>

                        <!-- Cards Summary -->
                        <Border Grid.Row="0" Background="Transparent" Padding="16,10,16,4" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="TOTAL SHEETS" FontSize="9" Foreground="#71717A" FontWeight="Bold"/>
                                        <TextBlock x:Name="sheets_total_text" Text="0" FontSize="22" FontWeight="Bold" Foreground="#18181B"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="SELECTED" FontSize="9" Foreground="#71717A" FontWeight="Bold"/>
                                        <TextBlock x:Name="sheets_selected_text" Text="0" FontSize="22" FontWeight="Bold" Foreground="#3B82F6"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="CATEGORIES" FontSize="9" Foreground="#71717A" FontWeight="Bold"/>
                                        <TextBlock x:Name="sheets_categories_text" Text="0" FontSize="22" FontWeight="Bold" Foreground="#10B981"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="PENDING CHANGES" FontSize="9" Foreground="#71717A" FontWeight="Bold"/>
                                        <TextBlock x:Name="sheets_changes_text" Text="0" FontSize="22" FontWeight="Bold" Foreground="#71717A"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- DataGrid & Filters -->
                        <Grid Grid.Row="1" Margin="16,0,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Filters & Quick Tools Panel -->
                            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,10,12,10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="SEARCH" FontSize="11" FontWeight="Bold" Margin="0,0,0,6" Foreground="#9A9AA2"/>
                                        <Border Margin="0,0,0,16" Height="36"
                                                Background="#F4F4F6" BorderBrush="#E6E6EA" BorderThickness="1"
                                                CornerRadius="18" Padding="10,0,10,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Data="M11 4 A7 7 0 1 0 11 18 A7 7 0 1 0 11 4 M21 21 L16.7 16.7"
                                                      Stroke="#71717A" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox x:Name="sheets_search_box" Grid.Column="1"
                                                         Style="{StaticResource T3InputField}" Tag="Search sheets…"
                                                         Background="Transparent" BorderThickness="0" Padding="0"
                                                         VerticalAlignment="Center" Height="24" FontSize="13.5"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="FILTER BY GROUP" FontSize="11" FontWeight="Bold" Margin="0,0,0,6" Foreground="#9A9AA2"/>
                                        <ComboBox x:Name="sheets_filter_combo" Style="{StaticResource T3ComboBoxSmall}" Margin="0,0,0,16" SelectedIndex="0">
                                            <ComboBoxItem Content="All Sheets"/>
                                            <ComboBoxItem Content="Placeholder Only"/>
                                            <ComboBoxItem Content="Non-Placeholder Only"/>
                                        </ComboBox>

                                        <TextBlock Text="QUICK SELECT" FontSize="11" FontWeight="Bold" Margin="0,0,0,6" Foreground="#9A9AA2"/>
                                        <Button x:Name="sheets_select_all_btn" Content="Select All" Style="{StaticResource SecondaryButton}" Height="30" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                                        <Button x:Name="sheets_clear_btn" Content="Clear Selection" Style="{StaticResource SecondaryButton}" Height="30" Margin="0,0,0,20" HorizontalAlignment="Stretch"/>

                                        <TextBlock Text="ADVANCED TOOLS" FontSize="11" FontWeight="Bold" Margin="0,0,0,8" Foreground="#9A9AA2"/>
                                        <Button x:Name="sheets_sets_btn" Content="ViewSheet Sets..." Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                                        <Button x:Name="sheets_place_views_btn" Content="Place Views on Sheet..." Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                                        <Button x:Name="sheets_custom_params_btn" Content="Custom Parameters..." Style="{StaticResource SecondaryButton}" Height="32" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- Right Sheets DataGrid -->
                            <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="6" Margin="0,10,0,10">
                                <DataGrid x:Name="sheets_grid" AutoGenerateColumns="False" IsReadOnly="False"
                                          SelectionMode="Extended" CanUserSortColumns="True" RowHeaderWidth="0"
                                          Background="White" BorderThickness="0"
                                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F4F4F6"
                                          RowBackground="White" AlternatingRowBackground="#FAFAFA"
                                          FontFamily="Hanken Grotesk" FontSize="13" Foreground="#27272A"
                                          HeadersVisibility="Column" Margin="4">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#FFFFFF"/>
                                            <Setter Property="Foreground" Value="#9A9AA2"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="White"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F4F4F6"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#F4F4F6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Background="Transparent" Padding="0">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#27272A"/>
                                                </Trigger>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Sheet Number" Binding="{Binding SheetNumber}" Width="110" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Sheet Name" Binding="{Binding Name}" Width="250" IsReadOnly="False"/>
                                        <DataGridCheckBoxColumn Header="Placeholder" Binding="{Binding IsPlaceholder}" Width="90" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Designed By" Binding="{Binding DesignedBy}" Width="120" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Checked By" Binding="{Binding CheckedBy}" Width="120" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Approved By" Binding="{Binding ApprovedBy}" Width="120" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Drawn By" Binding="{Binding DrawnBy}" Width="120" IsReadOnly="False"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <!-- Actions Footer -->
                        <Border Grid.Row="2" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="12,8">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button x:Name="sheets_excel_btn" Content="Excel Export/Import" Style="{StaticResource SuccessButton}" Width="150" Margin="0,0,8,0"/>
                                    <Button x:Name="sheets_refresh_btn" Content="Refresh List" Style="{StaticResource SecondaryButton}" Width="110"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="sheets_apply_btn" Content="Apply Changes" Style="{StaticResource PrimaryButton}" Width="130" Margin="0,0,8,0"/>
                                    <Button x:Name="sheets_close_btn" Content="Close" Style="{StaticResource SecondaryButton}" Width="80"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 2: SHEET RENUMBER -->
                <TabItem x:Name="tab_renumber_item">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>    <!-- Renumber inputs & preview -->
                            <RowDefinition Height="Auto"/> <!-- Renumber actions footer -->
                        </Grid.RowDefinitions>

                        <!-- Renumber Content -->
                        <Grid Grid.Row="0" Margin="16,16,16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Controls Card -->
                            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,16,0">
                                <StackPanel>
                                    <TextBlock Text="RENUMBER CONFIGURATION" FontSize="11" FontWeight="Bold" Margin="0,0,0,16" Foreground="#9A9AA2"/>

                                    <TextBlock Text="Prefix:" FontSize="9" Margin="0,0,0,4" Foreground="#71717A"/>
                                    <TextBox x:Name="renum_prefix_box" Style="{StaticResource T3InputFieldSmall}" Margin="0,0,0,12"/>

                                    <TextBlock Text="Starting Number:" FontSize="9" Margin="0,0,0,4" Foreground="#71717A"/>
                                    <TextBox x:Name="renum_start_box" Style="{StaticResource T3InputFieldSmall}" Margin="0,0,0,12" Text="1"/>

                                    <TextBlock Text="Increment Step:" FontSize="9" Margin="0,0,0,4" Foreground="#71717A"/>
                                    <TextBox x:Name="renum_step_box" Style="{StaticResource T3InputFieldSmall}" Margin="0,0,0,12" Text="1"/>

                                    <TextBlock Text="Suffix:" FontSize="9" Margin="0,0,0,4" Foreground="#71717A"/>
                                    <TextBox x:Name="renum_suffix_box" Style="{StaticResource T3InputFieldSmall}" Margin="0,0,0,24"/>

                                    <Border Background="#FFF6E6" BorderBrush="#FFF6E6" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,20">
                                        <StackPanel>
                                            <TextBlock Text="Instructions:" FontWeight="Bold" Foreground="#8A6308" FontSize="10" Margin="0,0,0,4"/>
                                            <TextBlock Text="1. Select sheet rows in the right preview grid.&#x0a;2. Set prefix, starting number, and step.&#x0a;3. Click Preview/Renumber." FontSize="9.5" Foreground="#8A6308" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Right Renumber Preview Grid -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="SELECT SHEETS TO RENUMBER" FontSize="11" FontWeight="Bold" Margin="0,0,0,8" Foreground="#9A9AA2"/>

                                <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="6">
                                    <DataGrid x:Name="renum_grid" AutoGenerateColumns="False" IsReadOnly="True"
                                              SelectionMode="Extended" CanUserSortColumns="True" RowHeaderWidth="0"
                                              Background="White" BorderThickness="0"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F4F4F6"
                                              RowBackground="White" AlternatingRowBackground="#FAFAFA"
                                              FontFamily="Hanken Grotesk" FontSize="13" Foreground="#27272A"
                                              HeadersVisibility="Column" Margin="4">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                <Setter Property="Foreground" Value="#9A9AA2"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="10,8"/>
                                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            </Style>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F4F4F6"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#F4F4F6"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="DataGridCell">
                                                            <Border Background="Transparent" Padding="0">
                                                                <ContentPresenter VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#27272A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Original Number" Binding="{Binding orig_number}" Width="150"/>
                                            <DataGridTextColumn Header="Sheet Name" Binding="{Binding name}" Width="250"/>
                                            <DataGridTextColumn Header="Preview New Number" Binding="{Binding preview_number}" Width="180"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- Renumber Footer Actions -->
                        <Border Grid.Row="1" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="12,8">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button x:Name="renum_refresh_btn" Content="Refresh Sheets" Style="{StaticResource SecondaryButton}" Width="130"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="renum_preview_btn" Content="Preview Changes" Style="{StaticResource AccentButton}" Width="130" Margin="0,0,8,0"/>
                                    <Button x:Name="renum_run_btn" Content="Renumber Selected" Style="{StaticResource SuccessButton}" Width="150" Margin="0,0,8,0"/>
                                    <Button x:Name="renum_close_btn" Content="Close" Style="{StaticResource SecondaryButton}" Width="80"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Grid.Column="1" Background="#F4F4F6" BorderBrush="#DCDCE0"
                    BorderThickness="0,1,0,0" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="© Copyright by T3Lab" FontSize="11" Foreground="#F59E0B" VerticalAlignment="Center"/>
                        <Border Width="1" Height="14" Background="#DCDCE0" Margin="12,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txt_status_bar" Text="Ready"
                                   FontSize="13.5" Foreground="#71717A" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
