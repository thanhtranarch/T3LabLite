                                    <TextBlock x:Name="txt_health_summary" Text="Run diagnostics to analyze model health." FontSize="12.5" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="txt_health_summary_metrics" Text="" FontSize="11.5" Foreground="#64748B" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="txt_health_last_run" Text="Last analyzed: --" FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="txt_health_doc_name" Text="Model: --" FontSize="11.5" Foreground="#64748B" Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <!-- Right Actions & Score -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button x:Name="btn_health_run" Style="{StaticResource PrimaryButton}" Content="⟳ Re-Analyze" Height="32" Padding="14,0" Margin="0,0,8,0"/>
                                        <Button x:Name="btn_health_export" Style="{StaticResource SecondaryButton}" Content="Export Report" Height="32" Padding="14,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txt_health_weighted_score" Text="Weighted Score: --/100" FontSize="11" Foreground="#475569" HorizontalAlignment="Right"/>
                                    <TextBlock x:Name="txt_health_weighted_grade" Text="Grade: --" FontSize="11" Foreground="#475569" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Row 1: Health Scale Legend -->
                        <Border Grid.Row="1" Background="#FFFBEB" BorderBrush="#FEF3C7" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Health Scale:" FontWeight="SemiBold" Foreground="#92400E" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Border Background="#10B981" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"><TextBlock Text="Good" Foreground="White" FontSize="11" FontWeight="SemiBold"/></Border>
                                <Border Background="#84CC16" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"><TextBlock Text="Acceptable" Foreground="White" FontSize="11" FontWeight="SemiBold"/></Border>
                                <Border Background="#F59E0B" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"><TextBlock Text="Warning" Foreground="White" FontSize="11" FontWeight="SemiBold"/></Border>
                                <Border Background="#F97316" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"><TextBlock Text="Concerning" Foreground="White" FontSize="11" FontWeight="SemiBold"/></Border>
                                <Border Background="#EF4444" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"><TextBlock Text="Critical" Foreground="White" FontSize="11" FontWeight="SemiBold"/></Border>
                                <Border Background="#B91C1C" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"><TextBlock Text="Severe" Foreground="White" FontSize="11" FontWeight="SemiBold"/></Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- Row 2: DataGrid -->
                        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="1" Margin="0,0,0,14">
                            <DataGrid x:Name="dg_health_metrics" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8FAFC" Background="White" BorderBrush="Transparent" BorderThickness="0" RowHeight="52" HeadersVisibility="Column" FontFamily="Hanken Grotesk" FontSize="12.5" IsReadOnly="True">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#0F172A"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="Height" Value="38"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E2E8F0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Metric" Binding="{Binding label}" Width="150"/>
                                    
                                    <!-- Value with Colored Background -->
                                    <DataGridTemplateColumn Header="Value" Width="85">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding value_bg}" CornerRadius="6" Padding="6,4" Margin="6" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding value_str}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <!-- Visual Health Indicator -->
                                    <DataGridTemplateColumn Header="Health Indicator" Width="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Margin="10,6" VerticalAlignment="Center">
                                                    <Border Background="#ECECEF" Height="10" CornerRadius="5"/>
                                                    <Border Background="{Binding indicator_color}" HorizontalAlignment="Left" Width="{Binding indicator_width}" Height="10" CornerRadius="5"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <!-- Multi-line Status -->
                                    <DataGridTemplateColumn Header="Status" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="6,4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding status_title_full}" FontWeight="Bold" Foreground="{Binding status_fg}"/>
                                                    <TextBlock Text="{Binding weight_stars}" FontSize="11" Foreground="#475569" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding thresholds_text}" FontSize="10.5" Foreground="#94A3B8" Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <!-- Action Select Button -->
                                    <DataGridTemplateColumn Header="Action" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="→ Select" Visibility="{Binding select_visibility}" Click="on_health_metric_select" Style="{StaticResource SecondaryButton}" Height="26" Padding="8,0" FontSize="11.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        
                        <!-- Row 3: Recommendations Panel & Worksharing Performance -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="420"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Left: Recommendations Panel -->
                            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,14,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="RECOMMENDATIONS" FontSize="12" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,10"/>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ListBox x:Name="lst_health_recommendations" BorderThickness="0" Background="Transparent">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                                        <Ellipse Fill="{Binding bullet_brush}" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding text}" FontSize="12" Foreground="#3F3F46" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                            
                            <!-- Right: Sync & Open Performance by User -->
                            <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="SYNC &amp; OPEN PERFORMANCE BY USER" FontSize="12" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,10"/>
                                    <DataGrid x:Name="dg_sync_performance" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8FAFC" Background="White" BorderBrush="Transparent" BorderThickness="0" RowHeight="26" HeadersVisibility="Column" FontFamily="Hanken Grotesk" FontSize="11" IsReadOnly="True" MaxHeight="100">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                <Setter Property="Foreground" Value="#475569"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="6,4"/>
                                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="Height" Value="24"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="User" Binding="{Binding user}" Width="*"/>
                                            <DataGridTextColumn Header="Avg Sync (s)" Binding="{Binding avg_sync}" Width="95"/>
                                            <DataGridTextColumn Header="Avg Open (s)" Binding="{Binding avg_open}" Width="95"/>
                                            <DataGridTextColumn Header="Syncs" Binding="{Binding sync_count}" Width="55"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem>
                    <Grid x:Name="grid_model_checker" Background="Transparent" Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Top Bar -->
                        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="0,0,0,14" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Checkset Name:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#3F3F46" Margin="0,0,10,0"/>
                                <ComboBox x:Name="cb_checkset" Grid.Column="1" Height="32" Style="{StaticResource T3ComboBoxSmall}"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <Button x:Name="btn_checker_run" Style="{StaticResource PrimaryButton}" Content="Run Compliance Check" Height="32" Padding="14,0" Margin="0,0,8,0"/>
                                    <Button x:Name="btn_checker_export" Style="{StaticResource SecondaryButton}" Content="Export Report" Height="32" Padding="14,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Results Table -->
                        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="1">
                            <DataGrid x:Name="dg_checker_results" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8FAFC" Background="White" BorderBrush="Transparent" BorderThickness="0" RowHeight="32" HeadersVisibility="Column" FontFamily="Hanken Grotesk" FontSize="12.5" IsReadOnly="True">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#0F172A"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="Height" Value="38"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E2E8F0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="70"/>
                                    <DataGridTextColumn Header="Category" Binding="{Binding category}" Width="120"/>
                                    <DataGridTextColumn Header="Severity" Binding="{Binding severity}" Width="80"/>
                                    <DataGridTextColumn Header="Rule Name" Binding="{Binding name}" Width="240"/>
                                    <DataGridTextColumn Header="Result" Binding="{Binding status}" Width="80"/>
                                    <DataGridTextColumn Header="Message / Details" Binding="{Binding message}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem>
                    <Grid x:Name="grid_warning_manager" Background="Transparent" Margin="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Left: Grouped Warnings -->
                        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Margin="0,0,14,0" Padding="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DataGrid x:Name="dg_warning_groups" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8FAFC" Background="White" BorderBrush="Transparent" BorderThickness="0" RowHeight="32" HeadersVisibility="Column" FontFamily="Hanken Grotesk" FontSize="12.5" IsReadOnly="True">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Setter Property="Foreground" Value="#0F172A"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Height" Value="38"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#E2E8F0"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Warning Message" Binding="{Binding description}" Width="*"/>
                                        <DataGridTextColumn Header="Count" Binding="{Binding count}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10" Background="#F8FAFC">
                                    <Button x:Name="btn_warning_reload" Style="{StaticResource SecondaryButton}" Content="Reload List" Height="32" Margin="0,0,8,0"/>
                                    <Button x:Name="btn_warning_autofix" Style="{StaticResource DangerButton}" Content="Resolve Overlapping Duplicates" Height="32" Margin="0,0,8,0" Padding="14,0"/>
                                    <Button x:Name="btn_warning_export" Style="{StaticResource SecondaryButton}" Content="Export Warnings" Height="32"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Right: Elements involved -->
                        <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="ELEMENTS IN WARNING:" FontSize="12.5" FontWeight="Bold" Foreground="#71717A" Margin="0,0,0,10"/>
                                <ListBox x:Name="lst_warning_elements" Grid.Row="1" BorderThickness="0" FontSize="12.5" SelectionMode="Extended"/>
                                <Button x:Name="btn_warning_select_elements" Grid.Row="2" Style="{StaticResource PrimaryButton}" Content="Select in Model" Height="36" Margin="0,12,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem>
                    <Grid x:Name="grid_model_cleanup" Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Nested toggle buttons for Cleanup options -->
                        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="14,6">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="btn_sub_smart_purge" Content="Smart Purge" IsChecked="True" Margin="0,0,12,0" FontWeight="SemiBold"/>
                                <RadioButton x:Name="btn_sub_advanced_purge" Content="Advanced Purge" Margin="0,0,12,0" FontWeight="SemiBold"/>
                                <RadioButton x:Name="btn_sub_smart_delete" Content="Smart Delete" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <TabControl x:Name="cleanup_tab_control" Grid.Row="1" BorderThickness="0" Background="Transparent">
                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </TabControl.ItemContainerStyle>
                            <TabItem>
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="1">
                                        <DataGrid x:Name="dg_smart_purge" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8FAFC" Background="White" BorderThickness="0" RowHeight="32" HeadersVisibility="Column" FontFamily="Hanken Grotesk" FontSize="12.5">
                                            <DataGrid.ColumnHeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                    <Setter Property="Foreground" Value="#0F172A"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Padding" Value="10,8"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                    <Setter Property="Height" Value="38"/>
                                                </Style>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#E2E8F0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="Purge?" Binding="{Binding is_selected}" Width="60"/>
                                                <DataGridTextColumn Header="Type / Name" Binding="{Binding name}" Width="*" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Category" Binding="{Binding category}" Width="150" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Unused Instances" Binding="{Binding count}" Width="120" IsReadOnly="True"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button x:Name="btn_smart_purge_check_all" Style="{StaticResource SecondaryButton}" Content="Select All" Height="32" Margin="0,0,8,0"/>
                                        <Button x:Name="btn_smart_purge_uncheck_all" Style="{StaticResource SecondaryButton}" Content="Deselect All" Height="32" Margin="0,0,8,0"/>
                                        <Button x:Name="btn_smart_purge_run" Style="{StaticResource DangerButton}" Content="Purge Selected" Height="32" Padding="16,0"/>
                                    </StackPanel>
                                </Grid>
                            </TabItem>
                            <TabItem>
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="SELECT DEEP CLEANUP CATEGORIES" FontSize="14" FontWeight="Bold" Foreground="#18181B" Margin="0,0,0,16"/>
                                            <CheckBox x:Name="chk_adv_views" Style="{StaticResource T3CheckBox}" Content="Purge Unused Views (not placed on sheets)" Margin="0,0,0,12"/>
                                            <CheckBox x:Name="chk_adv_templates" Style="{StaticResource T3CheckBox}" Content="Purge Unused View Templates" Margin="0,0,0,12"/>
                                            <CheckBox x:Name="chk_adv_filters" Style="{StaticResource T3CheckBox}" Content="Purge Unused View Filters" Margin="0,0,0,12"/>
                                            <CheckBox x:Name="chk_adv_materials" Style="{StaticResource T3CheckBox}" Content="Purge Unused Materials" Margin="0,0,0,12"/>
                                            <CheckBox x:Name="chk_adv_dwg" Style="{StaticResource T3CheckBox}" Content="Purge Unused CAD Imports / Links" Margin="0,0,0,12"/>
                                            <CheckBox x:Name="chk_adv_styles" Style="{StaticResource T3CheckBox}" Content="Purge Unused Line Styles / Fill Patterns" Margin="0,0,0,12"/>
                                        </StackPanel>
                                    </Border>
                                    <Button x:Name="btn_adv_purge_run" Grid.Row="1" Style="{StaticResource DangerButton}" Content="Run Deep Purge" Height="36" Padding="24,0" HorizontalAlignment="Right" Margin="0,14,0,0"/>
                                </Grid>
                            </TabItem>
                            <TabItem>
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Top ID entry -->
                                    <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="0,0,0,14" Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Element IDs to Delete:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#3F3F46" Margin="0,0,10,0"/>
                                            <TextBox x:Name="tb_delete_ids" Grid.Column="1" Height="32" Style="{StaticResource T3InputFieldSmall}" Margin="0,0,10,0"/>
                                            <Button x:Name="btn_delete_analyze" Grid.Column="2" Style="{StaticResource PrimaryButton}" Content="Analyze Dependencies" Height="32" Padding="14,0"/>
                                        </Grid>
                                    </Border>
                                    <!-- Dependency Tree/List -->
                                    <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="DEPENDENCY MAP (Elements that will also be deleted):" FontSize="12.5" FontWeight="Bold" Foreground="#71717A" Margin="0,0,0,10"/>
                                            <ListBox x:Name="lst_delete_dependencies" Grid.Row="1" BorderThickness="0" FontFamily="Consolas" FontSize="12"/>
                                        </Grid>
                                    </Border>
                                    <!-- Danger Delete Button -->
                                    <Button x:Name="btn_delete_run" Grid.Row="2" Style="{StaticResource DangerButton}" Content="Delete Elements Safely" Height="36" Padding="24,0" HorizontalAlignment="Right" Margin="0,14,0,0" IsEnabled="False"/>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>
                <TabItem>
                    <Grid x:Name="grid_special_audits" Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Nested toggle buttons to choose between In-Place and Material List -->
                        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="14,6">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="btn_sub_inplace" Content="In-Place Models" IsChecked="True" Margin="0,0,12,0" FontWeight="SemiBold"/>
                                <RadioButton x:Name="btn_sub_material" Content="Material List" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <TabControl x:Name="sub_tab_control" Grid.Row="1" BorderThickness="0" Background="Transparent">
                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </TabControl.ItemContainerStyle>
                            <TabItem>
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="1">
                                        <DataGrid x:Name="dg_special_inplace" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8FAFC" Background="White" BorderThickness="0" RowHeight="32" HeadersVisibility="Column" FontFamily="Hanken Grotesk" FontSize="12.5" IsReadOnly="True">
                                            <DataGrid.ColumnHeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                    <Setter Property="Foreground" Value="#0F172A"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Padding" Value="10,8"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                    <Setter Property="Height" Value="38"/>
                                                </Style>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#E2E8F0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Element ID" Binding="{Binding id}" Width="90"/>
                                                <DataGridTextColumn Header="Category" Binding="{Binding category}" Width="150"/>
                                                <DataGridTextColumn Header="Family Name" Binding="{Binding family_name}" Width="*"/>
                                                <DataGridTextColumn Header="Type Name" Binding="{Binding type_name}" Width="200"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button x:Name="btn_special_inplace_reload" Style="{StaticResource SecondaryButton}" Content="Reload" Height="32" Margin="0,0,8,0"/>
                                        <Button x:Name="btn_special_inplace_select" Style="{StaticResource PrimaryButton}" Content="Select in Model" Height="32" Margin="0,0,8,0" Padding="14,0"/>
                                        <Button x:Name="btn_special_inplace_delete" Style="{StaticResource DangerButton}" Content="Delete Selected" Height="32" Padding="14,0"/>
                                    </StackPanel>
                                </Grid>
                            </TabItem>
                            <TabItem>
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="1">
                                        <DataGrid x:Name="dg_special_materials" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single" GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8FAFC" Background="White" BorderThickness="0" RowHeight="32" HeadersVisibility="Column" FontFamily="Hanken Grotesk" FontSize="12.5" IsReadOnly="True">
                                            <DataGrid.ColumnHeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                    <Setter Property="Foreground" Value="#0F172A"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Padding" Value="10,8"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                    <Setter Property="Height" Value="38"/>
                                                </Style>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#E2E8F0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Category" Binding="{Binding category}" Width="150"/>
                                                <DataGridTextColumn Header="Material Name" Binding="{Binding name}" Width="*"/>
                                                <DataGridTextColumn Header="Volume (m³)" Binding="{Binding volume_str}" Width="120"/>
                                                <DataGridTextColumn Header="Area (m²)" Binding="{Binding area_str}" Width="120"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button x:Name="btn_special_materials_reload" Style="{StaticResource SecondaryButton}" Content="Reload" Height="32" Margin="0,0,8,0"/>
                                        <Button x:Name="btn_special_materials_export" Style="{StaticResource SuccessButton}" Content="Export to CSV" Height="32" Padding="16,0"/>
                                    </StackPanel>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- STATUS BAR / FOOTER -->
            <Border Grid.Row="2" Grid.Column="1" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Copyright, then Status right beside it -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="© Copyright by T3Lab" FontSize="11" Foreground="#F59E0B" VerticalAlignment="Center"/>
                        <Border Width="1" Height="14" Background="#DCDCE0" Margin="12,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="status_text" Text="Ready" FontSize="13.5" Foreground="#71717A" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: progress bar (collapsed when idle) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="16,0,0,0">
                        <ProgressBar x:Name="progress_bar" Width="200" Height="8" Minimum="0" Maximum="100" Value="0"
                                     Background="#ECECEF" Foreground="#C2410C" BorderThickness="0"
                                     VerticalAlignment="Center" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
