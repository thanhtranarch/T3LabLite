<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ManaPara"
        Width="1050" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#E4E4E7"
        FontFamily="Hanken Grotesk">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="22"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ═══ T3LAB SHARED STYLES v2 — AUTO-SYNCED, DO NOT EDIT (edit lib/GUI/Resources/WPF_styles.xaml, then run dev/sync_wpf_styles.py) ═══ -->
        <!-- Central Color Brushes (Lumina / T3Lab Standard System) -->
        <SolidColorBrush x:Key="T3PrimaryInkBrush" Color="#18181B"/>
        <SolidColorBrush x:Key="T3PrimaryTextBrush" Color="#27272A"/>
        <SolidColorBrush x:Key="T3SecondaryTextBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="T3TertiaryTextBrush" Color="#71717A"/>
        <SolidColorBrush x:Key="T3DisabledBorderBrush" Color="#9A9AA2"/>
        <SolidColorBrush x:Key="T3MainAppBgBrush" Color="#E4E4E7"/>
        <SolidColorBrush x:Key="T3ComponentBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="T3InputFieldBgBrush" Color="#F4F4F6"/>
        
        <!-- Semantic & Status Brushes -->
        <SolidColorBrush x:Key="T3SuccessBgBrush" Color="#EAF8F0"/>
        <SolidColorBrush x:Key="T3SuccessTextBrush" Color="#157038"/>
        <SolidColorBrush x:Key="T3SuccessBorderBrush" Color="#09734B"/>
        <SolidColorBrush x:Key="T3SuccessAccentBrush" Color="#0B8A5A"/>
        
        <SolidColorBrush x:Key="T3WarningBgBrush" Color="#FFF6E6"/>
        <SolidColorBrush x:Key="T3WarningTextBrush" Color="#8A6308"/>
        <SolidColorBrush x:Key="T3WarningAccentBrush" Color="#F5CE5A"/>
        
        <SolidColorBrush x:Key="T3DangerBgBrush" Color="#FDECEC"/>
        <SolidColorBrush x:Key="T3DangerTextBrush" Color="#D23B3B"/>
        <SolidColorBrush x:Key="T3DangerAccentBrush" Color="#F87171"/>
        
        <SolidColorBrush x:Key="T3ProgressActionBrush" Color="#C2410C"/>

        <!-- TERTIARY BUTTON - soft gray background, dark text -->
        <Style x:Key="TertiaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#ECECEF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E2E6"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#ECECEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sleek Modern ComboBox -->
        <Style x:Key="T3ComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Content -->
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                                      
                                    <!-- Toggle Button (Arrow) -->
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    
                                    <!-- Arrow Icon -->
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            
                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="true"
                                   IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="13"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Toggle Switch Style (CheckBox) -->
        <Style x:Key="T3ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="0" 
                                              Focusable="False" 
                                              HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                              
                            <!-- Toggle Track -->
                            <Border x:Name="toggleTrack" 
                                    Grid.Column="1"
                                    Width="42" Height="24"
                                    Background="#DCDCE2"
                                    CornerRadius="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <!-- Toggle Knob -->
                                <Ellipse x:Name="toggleKnob"
                                         Width="20" Height="20"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="2,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="1" Direction="270" Color="Black" Opacity="0.15" BlurRadius="2"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#18181B"/>
                                <Setter TargetName="toggleKnob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="toggleKnob" Property="Fill" Value="#9A9AA2"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Slider -->
        <Style x:Key="T3Slider" TargetType="Slider">
            <Setter Property="Background" Value="#E4E4E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Border x:Name="TrackBackground"
                                    Grid.Row="1"
                                    Height="6"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"/>
                                    
                            <!-- Track Fill and Thumb -->
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="#C2410C" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="18" Height="18"
                                                         Fill="White"
                                                         Stroke="#C2410C"
                                                         StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="2" Direction="270" Color="#C2410C" Opacity="0.3" BlurRadius="4"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field -->
        <Style x:Key="T3InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Modern GroupBox Card -->
        <Style x:Key="T3PremiumCard" TargetType="GroupBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Card Header -->
                                <Border Grid.Row="0" 
                                        Background="#FFFFFF"
                                        Padding="16,12"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter ContentSource="Header"
                                                      TextBlock.FontSize="14"
                                                      TextBlock.FontWeight="Bold"
                                                      TextBlock.Foreground="#18181B"
                                                      TextBlock.FontFamily="Hanken Grotesk"/>
                                </Border>
                                <!-- Card Content -->
                                <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Top Navigation Tab Style -->
        <Style x:Key="T3TopNavTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON - solid deep slate, white text -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#18181B"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SECONDARY BUTTON - white background, border and text slate -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#DEDEE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFB"/>
                    <Setter Property="BorderBrush" Value="#CFCFD5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="BorderBrush" Value="#E6E6EA"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GHOST BUTTON -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#52525B"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                    <Setter Property="Foreground" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E2E2E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SUCCESS BUTTON -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0B8A5A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#09734B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0B8A5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#D23B3B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F87171"/>
                    <Setter Property="Foreground" Value="#1F1F23"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ACCENT BUTTON -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#18181B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Icon Button Style -->
        <Style x:Key="T3SidebarButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F4F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- WINDOW CONTROL BUTTON -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#18181B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E4E4E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CLOSE BUTTON -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Premium CheckBox Style -->
        <Style x:Key="T3CheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBoxBorder" 
                                    Grid.Column="0"
                                    Width="18" Height="18"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="1.5"
                                    Background="White"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Path x:Name="optionMark" 
                                      Data="M4,9 L8,13 L14,5" 
                                      Stroke="White" 
                                      StrokeThickness="2" 
                                      StrokeStartLineCap="Round" 
                                      StrokeEndLineCap="Round" 
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#18181B"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="optionMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium RadioButton Style -->
        <Style x:Key="T3RadioButton" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="radioBorder" 
                                    Grid.Column="0"
                                    Width="20" Height="20"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="2"
                                    Background="White"
                                    CornerRadius="10"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Ellipse x:Name="radioDot"
                                         Width="9" Height="9"
                                         Fill="#18181B"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="radioDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="radioBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Scrollbar Styling -->
        <Style TargetType="{x:Type Thumb}" x:Key="ScrollBarThumbStyle">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="thumbBorder" Background="#A1A1AA" CornerRadius="2" Margin="0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#71717A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="true"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="false"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="4"/>
                    <Setter Property="Height" Value="Auto"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- SIDEBAR TOGGLE BUTTON (for icon-only sidebar filter/nav) -->
        <Style x:Key="T3SidebarToggle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#18181B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sleek Modern ComboBox Small -->
        <Style x:Key="T3ComboBoxSmall" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="10" Height="10"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                    AllowsTransparency="true"
                                    IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    Placement="Bottom"
                                    PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern ComboBox Small ToggleButton -->
        <Style x:Key="T3ComboBoxSmallToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  IsHitTestVisible="False"/>
                                <Path Grid.Column="1"
                                      Data="M6 9 L12 15 L18 9"
                                      Stroke="#71717A"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="10" Height="10"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field Small -->
        <Style x:Key="T3InputFieldSmall" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ProgressBar Style (Lumina Standard) -->
        <Style x:Key="T3ProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#ECECEF"/>
            <Setter Property="Foreground" Value="#C2410C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="BackgroundBorder" Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Border x:Name="PART_Track" ClipToBounds="True" CornerRadius="4" Background="Transparent">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="4"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Queue Item ProgressBar Style with complete trigger -->
        <Style x:Key="QueueProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource T3ProgressBar}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Progress}" Value="100">
                    <Setter Property="Foreground" Value="#10B981"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Pill RadioButton Style -->
        <Style x:Key="TabPillRadioButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="TabPills"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E2E6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ END T3LAB SHARED STYLES ═══ -->

        <!-- Icon-only sidebar nav RadioButton style -->
        <Style x:Key="T3SidebarIconNav" TargetType="RadioButton">
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#18181B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#A1A1AA" BorderThickness="1.5" CornerRadius="22" ClipToBounds="True" Background="#E4E4E7">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="66"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ SIDEBAR ═══ -->
            <Border Grid.Column="0" Grid.RowSpan="3"
                    Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,0,1,0"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid Margin="0,12,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Logo -->
                    <Border Grid.Row="0" Width="42" Height="42" CornerRadius="13"
                            Background="White" BorderBrush="#DCDCE0" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Path Data="M12 4 L20 8 L12 12 L4 8 Z M4 12 L12 16 L20 12 M4 16 L12 20 L20 16"
                              Stroke="#18181B" StrokeThickness="1.8" StrokeLineJoin="Round"
                              Width="20" Height="20" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- Browse Parameters -->
                    <RadioButton Grid.Row="1" x:Name="btn_nav_browse"
                                 Style="{StaticResource T3SidebarIconNav}"
                                 IsChecked="True" GroupName="ParamNav"
                                 Margin="0,0,0,6" ToolTip="Browse Parameters">
                        <Path Data="M7 2C4.2 2 2 4.2 2 7C2 9.8 4.2 12 7 12C9.8 12 12 9.8 12 7C12 4.2 9.8 2 7 2Z M11 11L16 16"
                              Width="18" Height="18" Stretch="Uniform"
                              StrokeThickness="1.5"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type RadioButton}}}"
                              Fill="Transparent"/>
                    </RadioButton>
                    <!-- Transfer Parameters -->
                    <RadioButton Grid.Row="2" x:Name="btn_nav_transfer"
                                 Style="{StaticResource T3SidebarIconNav}"
                                 GroupName="ParamNav"
                                 Margin="0,0,0,6" ToolTip="Transfer Parameters">
                        <Path Data="M2 6H14M14 6L11 3M14 6L11 9 M18 14H6M6 14L9 11M6 14L9 17"
                              Width="18" Height="18" Stretch="Uniform"
                              StrokeThickness="1.5"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type RadioButton}}}"
                              Fill="Transparent"/>
                    </RadioButton>
                    <!-- Parameter Loader -->
                    <RadioButton Grid.Row="3" x:Name="btn_nav_loader"
                                 Style="{StaticResource T3SidebarIconNav}"
                                 GroupName="ParamNav"
                                 Margin="0,0,0,6" ToolTip="Parameter Loader">
                        <Path Data="M10 2V13M10 13L6 9M10 13L14 9 M2 17H18"
                              Width="18" Height="18" Stretch="Uniform"
                              StrokeThickness="1.5"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type RadioButton}}}"
                              Fill="Transparent"/>
                    </RadioButton>
                </Grid>
            </Border>

            <!-- ═══ TITLE BAR ═══ -->
            <Grid Grid.Row="0" Grid.Column="1" Background="#F4F4F6" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Brand + title + subtitle -->
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="22,0,0,0" VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="ManaPara" FontSize="15" FontWeight="Bold" Foreground="#18181B"/>
                    <TextBlock Text="Browse, transfer and load parameters" FontSize="12.5" Foreground="#71717A" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Window control buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <Button x:Name="btn_minimize" Style="{StaticResource WinCtrlButton}"
                            ToolTip="Minimize"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="btn_maximize" Style="{StaticResource WinCtrlButton}"
                            ToolTip="Maximize"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="btn_close_chrome" Style="{StaticResource CloseButton}"
                            ToolTip="Close"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>

                <!-- Title bar bottom border -->
                <Border Grid.ColumnSpan="3" Height="1" VerticalAlignment="Bottom" Background="#DCDCE0"/>
            </Grid>

            <!-- ═══ MAIN CONTENT: TabControl ═══ -->
            <TabControl x:Name="tab_main" Grid.Row="1" Grid.Column="1"
                        Background="Transparent" BorderThickness="0" Padding="0">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <!-- Headerless template: bare content, no default TabControl chrome/padding -->
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </ControlTemplate>
                    </TabControl.Template>
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Width" Value="0"/>
                            <Setter Property="Height" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </TabControl.ItemContainerStyle>

                    <!-- ═══ TAB 1: BROWSE PARAMETERS ═══ -->
                    <TabItem>
                        <Grid Margin="10,8,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Filter Row -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Margin="0,0,6,0" Height="36"
                                        Background="#F4F4F6" BorderBrush="#E6E6EA" BorderThickness="1"
                                        CornerRadius="18" Padding="10,0,10,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Grid.Column="0" Data="M11 4 A7 7 0 1 0 11 18 A7 7 0 1 0 11 4 M21 21 L16.7 16.7"
                                              Stroke="#71717A" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox x:Name="txt_param_search" Grid.Column="1"
                                                 Style="{StaticResource T3InputField}" Tag="Search parameters…"
                                                 Background="Transparent" BorderThickness="0" Padding="0"
                                                 VerticalAlignment="Center" Height="24" FontSize="13.5"/>
                                    </Grid>
                                </Border>
                                <ComboBox x:Name="cmb_param_type"
                                          Grid.Column="1"
                                          Style="{StaticResource T3ComboBoxSmall}"
                                          Margin="0,0,6,0"/>
                                <ComboBox x:Name="cmb_param_binding"
                                          Grid.Column="2"
                                          Style="{StaticResource T3ComboBoxSmall}"
                                          Margin="0,0,6,0"/>
                                <Button x:Name="btn_param_refresh"
                                        Grid.Column="3"
                                        Content="Refresh"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" Padding="10,4"/>
                            </Grid>

                            <!-- DataGrid -->
                            <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Margin="0,0,0,8">
                                <DataGrid x:Name="dg_parameters"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          CanUserSortColumns="True"
                                          Background="White" BorderThickness="0"
                                          AlternatingRowBackground="#FAFAFA"
                                          FontFamily="Hanken Grotesk" FontSize="13" Foreground="#27272A"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F4F4F6"
                                          RowBackground="White"
                                          HeadersVisibility="Column" RowHeaderWidth="0" Margin="4">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#FFFFFF"/>
                                            <Setter Property="Foreground" Value="#9A9AA2"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="White"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F4F4F6"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#F4F4F6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Background="Transparent" Padding="0">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#27272A"/>
                                                </Trigger>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Parameter Name" Binding="{Binding name}" Width="*"/>
                                        <DataGridTextColumn Header="Type" Binding="{Binding param_type}" Width="80"/>
                                        <DataGridTextColumn Header="Data Type" Binding="{Binding data_type}" Width="90"/>
                                        <DataGridTextColumn Header="Group" Binding="{Binding group}" Width="140"/>
                                        <DataGridTextColumn Header="Binding" Binding="{Binding binding}" Width="70"/>
                                        <DataGridTextColumn Header="Categories" Binding="{Binding categories}" Width="180"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Action Row -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,4">
                                <Button x:Name="btn_param_edit_group" Content="Edit Group"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" Padding="10,4" Margin="0,0,6,0"/>
                                <Button x:Name="btn_param_edit_cats" Content="Edit Categories"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" Padding="10,4" Margin="0,0,6,0"/>
                                <Button x:Name="btn_param_edit_binding" Content="Edit Binding"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" Padding="10,4" Margin="0,0,6,0"/>
                                <Button x:Name="btn_param_export" Content="Export CSV"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" Padding="10,4" Margin="0,0,6,0"/>
                                <Button x:Name="btn_param_delete" Content="Delete"
                                        Style="{StaticResource DangerButton}"
                                        Height="28" Padding="10,4"/>
                            </StackPanel>

                        </Grid>
                    </TabItem>

                    <!-- ═══ TAB 2: TRANSFER PARAMETERS ═══ -->
                    <TabItem>
                        <Grid Margin="10,8,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="200"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Category selector -->
                            <Border Grid.Row="0" Background="White" BorderBrush="#DCDCE0"
                                    BorderThickness="1" CornerRadius="12" Padding="12,10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="300"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Category:" FontWeight="SemiBold"
                                               FontSize="13" Foreground="#18181B" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cmb_transfer_category" Grid.Column="1"
                                              Style="{StaticResource T3ComboBoxSmall}"
                                              Margin="10,0,0,0"/>
                                    <TextBlock x:Name="txt_transfer_count" Grid.Column="3"
                                               Text="0 elements" VerticalAlignment="Center"
                                               FontSize="12" Foreground="#71717A" FontStyle="Italic"/>
                                </Grid>
                            </Border>

                            <!-- Row 1: Source / Target split -->
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Source column -->
                                <Border Grid.Column="0" Background="White" BorderBrush="#DCDCE0"
                                        BorderThickness="1" CornerRadius="12" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="SOURCE Parameter (read from):"
                                                   FontWeight="SemiBold" FontSize="12" Foreground="#18181B"
                                                   Margin="0,0,0,6"/>
                                        <Border Grid.Row="1" Margin="0,0,0,6" Height="36"
                                                Background="#F4F4F6" BorderBrush="#E6E6EA" BorderThickness="1"
                                                CornerRadius="18" Padding="10,0,10,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Data="M11 4 A7 7 0 1 0 11 18 A7 7 0 1 0 11 4 M21 21 L16.7 16.7"
                                                      Stroke="#71717A" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox x:Name="txt_transfer_src_search" Grid.Column="1"
                                                         Style="{StaticResource T3InputField}" Tag="Search source parameters…"
                                                         Background="Transparent" BorderThickness="0" Padding="0"
                                                         VerticalAlignment="Center" Height="24" FontSize="13.5"/>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="pnl_transfer_source"/>
                                            </ScrollViewer>
                                        </Border>
                                        <TextBlock x:Name="txt_transfer_src_info" Grid.Row="3"
                                                   FontSize="10" Foreground="#71717A"
                                                   Margin="0,4,0,0" Text="Select a source parameter"/>
                                    </Grid>
                                </Border>

                                <!-- Arrow -->
                                <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#3B82F6" FontWeight="Bold"/>

                                <!-- Target column -->
                                <Border Grid.Column="2" Background="White" BorderBrush="#DCDCE0"
                                        BorderThickness="1" CornerRadius="12" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="TARGET Parameter (write to):"
                                                   FontWeight="SemiBold" FontSize="12" Foreground="#18181B"
                                                   Margin="0,0,0,6"/>
                                        <Border Grid.Row="1" Margin="0,0,0,6" Height="36"
                                                Background="#F4F4F6" BorderBrush="#E6E6EA" BorderThickness="1"
                                                CornerRadius="18" Padding="10,0,10,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0" Data="M11 4 A7 7 0 1 0 11 18 A7 7 0 1 0 11 4 M21 21 L16.7 16.7"
                                                      Stroke="#71717A" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox x:Name="txt_transfer_tgt_search" Grid.Column="1"
                                                         Style="{StaticResource T3InputField}" Tag="Search target parameters…"
                                                         Background="Transparent" BorderThickness="0" Padding="0"
                                                         VerticalAlignment="Center" Height="24" FontSize="13.5"/>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="pnl_transfer_target"/>
                                            </ScrollViewer>
                                        </Border>
                                        <TextBlock x:Name="txt_transfer_tgt_info" Grid.Row="3"
                                                   FontSize="10" Foreground="#71717A"
                                                   Margin="0,4,0,0" Text="Select a target parameter"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Row 2: Preview DataGrid -->
                            <Border Grid.Row="2" Background="White" BorderBrush="#DCDCE0"
                                    BorderThickness="1" CornerRadius="12" Padding="12,8" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                        <TextBlock Text="Preview:" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="#18181B" VerticalAlignment="Center"
                                                   DockPanel.Dock="Left"/>
                                        <Button x:Name="btn_transfer_preview" Content="Refresh Preview"
                                                Style="{StaticResource TertiaryButton}"
                                                DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                Height="28" Padding="10,4"/>
                                        <TextBlock x:Name="txt_transfer_preview_status" FontSize="11"
                                                   Foreground="#71717A" VerticalAlignment="Center"
                                                   Margin="12,0,0,0" FontStyle="Italic"/>
                                    </DockPanel>
                                    <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Margin="4">
                                        <DataGrid x:Name="dg_transfer_preview"
                                                  AutoGenerateColumns="False" IsReadOnly="True"
                                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                  BorderThickness="0" RowHeaderWidth="0"
                                                  RowHeight="32" FontSize="13"
                                                  FontFamily="Hanken Grotesk" Foreground="#27272A"
                                                  Background="White" AlternatingRowBackground="#FAFAFA"
                                                  HorizontalGridLinesBrush="#F4F4F6"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#FFFFFF"/>
                                                    <Setter Property="Foreground" Value="#9A9AA2"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="Padding" Value="10,8"/>
                                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                </Style>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F4F4F6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#F4F4F6"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="DataGridCell">
                                                                <Border Background="Transparent" Padding="0">
                                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="#27272A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Resources>
                                        </DataGrid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Row 3: Action bar -->
                            <Border Grid.Row="3" Background="#F4F4F6" BorderBrush="#DCDCE0"
                                    BorderThickness="1" CornerRadius="12" Padding="12,8">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button x:Name="btn_transfer_run" Content="Transfer Values"
                                                Style="{StaticResource SuccessButton}"
                                                IsEnabled="False" Margin="0,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txt_transfer_status" FontSize="11"
                                               Foreground="#71717A" VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ═══ TAB 3: PARAMETER LOADER ═══ -->
                    <TabItem>
                        <Grid Margin="10,8,10,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Import section -->
                            <Border Grid.Row="0" Background="White" BorderBrush="#DCDCE0"
                                    BorderThickness="1" CornerRadius="12" Padding="12,10" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="IMPORT REQUIREMENTS" FontSize="9" FontWeight="SemiBold"
                                               Foreground="#9A9AA2" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button x:Name="btn_loader_import_xml"
                                                Content="Import from XML"
                                                Style="{StaticResource AccentButton}"
                                                Height="28" Padding="14,6" Margin="0,0,8,0"/>
                                        <Button x:Name="btn_loader_import_excel"
                                                Content="Import from Excel"
                                                Style="{StaticResource TertiaryButton}"
                                                Height="28" Padding="14,6"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txt_loader_filepath" FontSize="11"
                                               Foreground="#71717A" TextWrapping="Wrap"
                                               Text="No file loaded" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="txt_loader_stats" FontSize="11"
                                               Foreground="#0B8A5A" FontWeight="SemiBold"
                                               Text="" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Row 1: Parameters DataGrid -->
                            <Border Grid.Row="1" Background="White" BorderBrush="#DCDCE0"
                                    BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Sub-header + select buttons -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Parameters to Load" FontWeight="Bold"
                                                   FontSize="12" Foreground="#18181B" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button x:Name="btn_loader_select_new" Content="New Only"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="28" Padding="8,4" Margin="0,0,4,0"/>
                                            <Button x:Name="btn_loader_select_all" Content="All"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="28" Padding="8,4" Margin="0,0,4,0" Width="45"/>
                                            <Button x:Name="btn_loader_select_none" Content="None"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="28" Padding="8,4" Width="55"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Parameter list DataGrid -->
                                    <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Margin="4">
                                        <DataGrid x:Name="dg_loader_params"
                                                  AutoGenerateColumns="False" IsReadOnly="False"
                                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                  BorderThickness="0" RowHeaderWidth="0"
                                                  RowHeight="32" FontSize="13"
                                                  FontFamily="Hanken Grotesk" Foreground="#27272A"
                                                  Background="White" AlternatingRowBackground="#FAFAFA"
                                                  HorizontalGridLinesBrush="#F4F4F6"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#FFFFFF"/>
                                                    <Setter Property="Foreground" Value="#9A9AA2"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="Padding" Value="10,8"/>
                                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                </Style>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F4F4F6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#F4F4F6"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="DataGridCell">
                                                                <Border Background="Transparent" Padding="0">
                                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="#27272A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="" Binding="{Binding is_selected}" Width="32"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding status}" Width="75"/>
                                                <DataGridTextColumn Header="Parameter Name" Binding="{Binding name}" Width="*"/>
                                                <DataGridTextColumn Header="Group Under" Binding="{Binding group}" Width="120"/>
                                                <DataGridTextColumn Header="Categories" Binding="{Binding categories}" Width="160"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Row 2: Progress + Action -->
                            <Border Grid.Row="2" Background="#F4F4F6" BorderBrush="#DCDCE0"
                                    BorderThickness="1" CornerRadius="12" Padding="12,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Progress bar (hidden when idle) -->
                                    <ProgressBar x:Name="prg_loader" Grid.Row="0"
                                                 Style="{StaticResource T3ProgressBar}"
                                                 Visibility="Collapsed" Margin="0,0,0,8"/>

                                    <!-- Action row -->
                                    <DockPanel Grid.Row="1">
                                        <Button x:Name="btn_loader_add"
                                                Content="Add Parameters to Project"
                                                Style="{StaticResource SuccessButton}"
                                                IsEnabled="False"
                                                DockPanel.Dock="Right"
                                                Margin="8,0,0,0"/>
                                        <TextBlock x:Name="txt_loader_status"
                                                   FontSize="12" Foreground="#71717A"
                                                   VerticalAlignment="Center" FontWeight="Medium"
                                                   Text="Import a config to begin."
                                                   TextWrapping="Wrap"/>
                                    </DockPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

            </TabControl>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Grid.Column="1" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="© Copyright by T3Lab" FontSize="11" Foreground="#F59E0B" VerticalAlignment="Center"/>
                        <Border Width="1" Height="14" Background="#DCDCE0" Margin="12,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txt_param_status_bar"
                                   Text=""
                                   FontSize="13.5" Foreground="#71717A" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
