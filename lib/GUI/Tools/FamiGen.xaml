<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FamiGen"
        Width="1100" Height="720"
        MinWidth="860" MinHeight="540"
        Background="#E4E4E7"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        FontFamily="Hanken Grotesk">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="22"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ═══ T3LAB SHARED STYLES v2 — AUTO-SYNCED, DO NOT EDIT (edit lib/GUI/Resources/WPF_styles.xaml, then run dev/sync_wpf_styles.py) ═══ -->
        <!-- Central Color Brushes (Lumina / T3Lab Standard System) -->
        <SolidColorBrush x:Key="T3PrimaryInkBrush" Color="#18181B"/>
        <SolidColorBrush x:Key="T3PrimaryTextBrush" Color="#27272A"/>
        <SolidColorBrush x:Key="T3SecondaryTextBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="T3TertiaryTextBrush" Color="#71717A"/>
        <SolidColorBrush x:Key="T3DisabledBorderBrush" Color="#9A9AA2"/>
        <SolidColorBrush x:Key="T3MainAppBgBrush" Color="#E4E4E7"/>
        <SolidColorBrush x:Key="T3ComponentBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="T3InputFieldBgBrush" Color="#F4F4F6"/>
        
        <!-- Semantic & Status Brushes -->
        <SolidColorBrush x:Key="T3SuccessBgBrush" Color="#EAF8F0"/>
        <SolidColorBrush x:Key="T3SuccessTextBrush" Color="#157038"/>
        <SolidColorBrush x:Key="T3SuccessBorderBrush" Color="#09734B"/>
        <SolidColorBrush x:Key="T3SuccessAccentBrush" Color="#0B8A5A"/>
        
        <SolidColorBrush x:Key="T3WarningBgBrush" Color="#FFF6E6"/>
        <SolidColorBrush x:Key="T3WarningTextBrush" Color="#8A6308"/>
        <SolidColorBrush x:Key="T3WarningAccentBrush" Color="#F5CE5A"/>
        
        <SolidColorBrush x:Key="T3DangerBgBrush" Color="#FDECEC"/>
        <SolidColorBrush x:Key="T3DangerTextBrush" Color="#D23B3B"/>
        <SolidColorBrush x:Key="T3DangerAccentBrush" Color="#F87171"/>
        
        <SolidColorBrush x:Key="T3ProgressActionBrush" Color="#C2410C"/>

        <!-- TERTIARY BUTTON - soft gray background, dark text -->
        <Style x:Key="TertiaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#ECECEF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E2E6"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#ECECEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sleek Modern ComboBox -->
        <Style x:Key="T3ComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Content -->
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                                      
                                    <!-- Toggle Button (Arrow) -->
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    
                                    <!-- Arrow Icon -->
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            
                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="true"
                                   IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="13"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Toggle Switch Style (CheckBox) -->
        <Style x:Key="T3ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="0" 
                                              Focusable="False" 
                                              HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                              
                            <!-- Toggle Track -->
                            <Border x:Name="toggleTrack" 
                                    Grid.Column="1"
                                    Width="42" Height="24"
                                    Background="#DCDCE2"
                                    CornerRadius="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <!-- Toggle Knob -->
                                <Ellipse x:Name="toggleKnob"
                                         Width="20" Height="20"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="2,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="1" Direction="270" Color="Black" Opacity="0.15" BlurRadius="2"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#18181B"/>
                                <Setter TargetName="toggleKnob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="toggleKnob" Property="Fill" Value="#9A9AA2"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Slider -->
        <Style x:Key="T3Slider" TargetType="Slider">
            <Setter Property="Background" Value="#E4E4E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Border x:Name="TrackBackground"
                                    Grid.Row="1"
                                    Height="6"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"/>
                                    
                            <!-- Track Fill and Thumb -->
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="#C2410C" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="18" Height="18"
                                                         Fill="White"
                                                         Stroke="#C2410C"
                                                         StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="2" Direction="270" Color="#C2410C" Opacity="0.3" BlurRadius="4"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field -->
        <Style x:Key="T3InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Modern GroupBox Card -->
        <Style x:Key="T3PremiumCard" TargetType="GroupBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Card Header -->
                                <Border Grid.Row="0" 
                                        Background="#FFFFFF"
                                        Padding="16,12"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter ContentSource="Header"
                                                      TextBlock.FontSize="14"
                                                      TextBlock.FontWeight="Bold"
                                                      TextBlock.Foreground="#18181B"
                                                      TextBlock.FontFamily="Hanken Grotesk"/>
                                </Border>
                                <!-- Card Content -->
                                <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Top Navigation Tab Style -->
        <Style x:Key="T3TopNavTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON - solid deep slate, white text -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#18181B"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SECONDARY BUTTON - white background, border and text slate -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#DEDEE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFB"/>
                    <Setter Property="BorderBrush" Value="#CFCFD5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="BorderBrush" Value="#E6E6EA"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GHOST BUTTON -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#52525B"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                    <Setter Property="Foreground" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E2E2E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SUCCESS BUTTON -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0B8A5A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#09734B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0B8A5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#D23B3B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F87171"/>
                    <Setter Property="Foreground" Value="#1F1F23"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ACCENT BUTTON -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#18181B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Icon Button Style -->
        <Style x:Key="T3SidebarButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F4F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- WINDOW CONTROL BUTTON -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#18181B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E4E4E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CLOSE BUTTON -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Premium CheckBox Style -->
        <Style x:Key="T3CheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBoxBorder" 
                                    Grid.Column="0"
                                    Width="18" Height="18"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="1.5"
                                    Background="White"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Path x:Name="optionMark" 
                                      Data="M4,9 L8,13 L14,5" 
                                      Stroke="White" 
                                      StrokeThickness="2" 
                                      StrokeStartLineCap="Round" 
                                      StrokeEndLineCap="Round" 
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#18181B"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="optionMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium RadioButton Style -->
        <Style x:Key="T3RadioButton" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="radioBorder" 
                                    Grid.Column="0"
                                    Width="20" Height="20"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="2"
                                    Background="White"
                                    CornerRadius="10"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Ellipse x:Name="radioDot"
                                         Width="9" Height="9"
                                         Fill="#18181B"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="radioDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="radioBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Scrollbar Styling -->
        <Style TargetType="{x:Type Thumb}" x:Key="ScrollBarThumbStyle">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="thumbBorder" Background="#A1A1AA" CornerRadius="2" Margin="0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#71717A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="true"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="false"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="4"/>
                    <Setter Property="Height" Value="Auto"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- SIDEBAR TOGGLE BUTTON (for icon-only sidebar filter/nav) -->
        <Style x:Key="T3SidebarToggle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#18181B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sleek Modern ComboBox Small -->
        <Style x:Key="T3ComboBoxSmall" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="10" Height="10"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                    AllowsTransparency="true"
                                    IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    Placement="Bottom"
                                    PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern ComboBox Small ToggleButton -->
        <Style x:Key="T3ComboBoxSmallToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  IsHitTestVisible="False"/>
                                <Path Grid.Column="1"
                                      Data="M6 9 L12 15 L18 9"
                                      Stroke="#71717A"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="10" Height="10"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field Small -->
        <Style x:Key="T3InputFieldSmall" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ProgressBar Style (Lumina Standard) -->
        <Style x:Key="T3ProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#ECECEF"/>
            <Setter Property="Foreground" Value="#C2410C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="BackgroundBorder" Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Border x:Name="PART_Track" ClipToBounds="True" CornerRadius="4" Background="Transparent">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="4"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Queue Item ProgressBar Style with complete trigger -->
        <Style x:Key="QueueProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource T3ProgressBar}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Progress}" Value="100">
                    <Setter Property="Foreground" Value="#10B981"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Pill RadioButton Style -->
        <Style x:Key="TabPillRadioButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="TabPills"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E2E6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ END T3LAB SHARED STYLES ═══ -->

        <!-- JSON code button -->
        <Style x:Key="CopyButton" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#059669"/></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#A1A1AA" BorderThickness="1.5" CornerRadius="22" ClipToBounds="True" Background="#E4E4E7">
        <Grid>
            <!-- Columns: Col 0 for left sidebar, Col 1 for main area -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="66"/>     <!-- Column 0: Left Sidebar Rail -->
                <ColumnDefinition Width="*"/>      <!-- Column 1: Main Content Area -->
            </Grid.ColumnDefinitions>

            <!-- Rows for Column 1 -->
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>       <!-- Row 0: Title Bar -->
                <RowDefinition Height="*"/>        <!-- Row 1: Content Card -->
                <RowDefinition Height="Auto"/>     <!-- Row 2: Status Bar / Footer -->
            </Grid.RowDefinitions>

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- COL 0: LEFT SIDEBAR ICON RAIL (spans all rows)              -->
            <!-- ════════════════════════════════════════════════════════════ -->
            <Border Grid.Column="0" Grid.RowSpan="3"
                    Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,0,1,0">
                <Grid Margin="0,16,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Logo -->
                        <RowDefinition Height="Auto"/> <!-- Mode: CAD -->
                        <RowDefinition Height="Auto"/> <!-- Mode: JSON -->
                        <RowDefinition Height="*"/>    <!-- Spacer -->
                    </Grid.RowDefinitions>

                    <!-- Logo: 3D cube wireframe logo -->
                    <Border Grid.Row="0" Width="42" Height="42" CornerRadius="13"
                            Background="White" BorderBrush="#DCDCE0" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Path Data="M12 4 L20 8 L12 12 L4 8 Z M4 12 L12 16 L20 12 M4 16 L12 20 L20 16" 
                              Stroke="#18181B" StrokeThickness="1.8" StrokeLineJoin="Round"
                              Width="20" Height="20" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Tab: From CAD -->
                    <ToggleButton x:Name="mode_cad" Grid.Row="1"
                                  Style="{StaticResource T3SidebarToggle}"
                                  Margin="0,0,0,8" IsChecked="True"
                                  ToolTip="From CAD"
                                  Click="nav_cad_clicked">
                        <Path Data="M4 4 h16 v14 h-16 z M4 9 h16 M10 9 v10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.6" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="19" Height="19" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ToggleButton>

                    <!-- Tab: From JSON -->
                    <ToggleButton x:Name="mode_json" Grid.Row="2"
                                  Style="{StaticResource T3SidebarToggle}"
                                  Margin="0,0,0,8"
                                  ToolTip="From JSON"
                                  Click="nav_json_clicked">
                        <Path Data="M4 2 h10 l5 5 v14 H4 z M14 2 v5 h5 M7 12 h8 M7 16 h5"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Width="19" Height="19" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ToggleButton>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- ROW 0 / COL 1: TITLE BAR                                    -->
            <!-- ════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Grid.Column="1" Background="White">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="22,0,0,0" VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="FamiGen" FontSize="15" FontWeight="Bold" Foreground="#18181B"/>
                    <TextBlock Text="Create Revit families from CAD blocks or JSON schema"
                               FontSize="12.5" Foreground="#71717A" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="btn_minimize" Style="{StaticResource WinCtrlButton}"
                            Click="minimize_button_clicked" ToolTip="Minimize">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="btn_maximize" Style="{StaticResource WinCtrlButton}"
                            Click="maximize_button_clicked" ToolTip="Maximize">
                        <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="btn_close" Style="{StaticResource CloseButton}"
                            Click="close_button_clicked" ToolTip="Close">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>

                <Border Grid.ColumnSpan="3" Height="1" VerticalAlignment="Bottom" Background="#E2E8F0"/>
            </Grid>

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- ROW 1 / COL 1: CONTENT AREA (Premium Card Container)        -->
            <!-- ════════════════════════════════════════════════════════════ -->
            <Border Grid.Column="1" Grid.Row="1"
                    Background="White" Margin="0"
                    CornerRadius="0" BorderThickness="0"
                    ClipToBounds="True">
                <Grid>
                    <!-- ─── PANEL: FROM CAD ─── -->
                    <Grid x:Name="panel_cad" Visibility="Visible">
                        <!-- ── CAD Blocks ── -->
                        <Grid x:Name="panel_cad_blocks" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- Configuration -->
                                <RowDefinition Height="Auto"/>  <!-- Info tip -->
                                <RowDefinition Height="Auto"/>  <!-- Filter bar -->
                                <RowDefinition Height="*"/>     <!-- DataGrid -->
                                <RowDefinition Height="Auto"/>  <!-- Action bar -->
                            </Grid.RowDefinitions>

                            <!-- Configuration -->
                            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CAD File:" VerticalAlignment="Center" Foreground="#0F172A" FontSize="12"/>
                                    <ComboBox x:Name="cad_file_combo" Grid.Row="0" Grid.Column="1"
                                              Style="{StaticResource T3ComboBoxSmall}" Margin="0,0,8,0"/>
                                    <Button Content="Scan Blocks" Grid.Row="0" Grid.Column="2"
                                            Style="{StaticResource PrimaryButton}" Click="scan_blocks_clicked"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Discipline:" VerticalAlignment="Center" Foreground="#0F172A" FontSize="12"/>
                                    <ComboBox x:Name="discipline_combo" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                              Style="{StaticResource T3ComboBoxSmall}"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Category:" VerticalAlignment="Center" Foreground="#0F172A" FontSize="12"/>
                                    <ComboBox x:Name="category_combo" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                              Style="{StaticResource T3ComboBoxSmall}"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Geometry:" VerticalAlignment="Center" Foreground="#0F172A" FontSize="12"/>
                                    <StackPanel Orientation="Horizontal" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2">
                                        <RadioButton x:Name="rb_3d_solid" Content=" 3D Solid / Extrusion" IsChecked="False" IsEnabled="False"
                                                     Style="{StaticResource T3RadioButton}" Margin="0,0,20,0" Foreground="#94A3B8"
                                                     FontSize="12" ToolTip="3D Solid — coming soon"/>
                                        <RadioButton x:Name="rb_2d_lines" Content=" 2D Model Lines Only" IsChecked="True"
                                                     Style="{StaticResource T3RadioButton}" Foreground="#0F172A" FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Output:" VerticalAlignment="Center" Foreground="#0F172A" FontSize="12"/>
                                    <TextBox x:Name="output_path" Grid.Row="8" Grid.Column="1"
                                             IsReadOnly="True" Style="{StaticResource T3InputFieldSmall}"
                                             Margin="0,0,8,0"/>
                                    <Button Content="Browse..." Grid.Row="8" Grid.Column="2"
                                            Style="{StaticResource SecondaryButton}" Click="browse_folder_clicked"/>
                                </Grid>
                            </Border>

                            <!-- Tip -->
                            <Border Grid.Row="1" Margin="16,10,16,0" Background="#F4F4F6" BorderBrush="#E6E6EA"
                                    BorderThickness="1" CornerRadius="14" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="20" Height="20" CornerRadius="10" Background="#18181B"
                                            VerticalAlignment="Top" Margin="0,1,8,0">
                                        <Path Data="M12 11 V16.5 M12 7.6 V7.62" Stroke="White" StrokeThickness="2.1"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Width="12" Height="12" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" FontSize="13" Foreground="#3F3F46" TextWrapping="Wrap">
                                        <Run Text="Tip. " FontWeight="Bold" Foreground="#18181B"/>
                                        <Run Text="Select a linked CAD file and click 'Scan Blocks' — category is auto-detected per block and can be overridden in the grid."/>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Filter bar -->
                            <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,1" Padding="16,8" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="14" Background="White">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       Foreground="#64748B" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                            <TextBox x:Name="txt_search" Grid.Column="1"
                                                     FontFamily="Hanken Grotesk" FontSize="12"
                                                     BorderThickness="0" Background="Transparent"
                                                     VerticalAlignment="Center" Padding="0,5"
                                                     TextChanged="search_text_changed"/>
                                            <TextBlock x:Name="txt_search_placeholder" Grid.Column="1" IsHitTestVisible="False"
                                                       Text="Search block name or layer…" FontFamily="Hanken Grotesk" FontSize="12"
                                                       Foreground="#94A3B8" VerticalAlignment="Center" Padding="2,5"/>
                                            <Button x:Name="btn_clear_search" Grid.Column="2"
                                                    Width="24" Height="24" Foreground="#64748B" Background="Transparent"
                                                    BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Margin="2,0"
                                                    Click="clear_search_clicked" Visibility="Collapsed">
                                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Suggested:" FontFamily="Hanken Grotesk" FontSize="12"
                                                   Foreground="#0F172A" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ComboBox x:Name="combo_filter_suggested"
                                                  Style="{StaticResource T3ComboBoxSmall}" Width="130"
                                                  SelectionChanged="filter_suggested_changed"/>
                                    </StackPanel>

                                    <TextBlock x:Name="txt_filter_count" Grid.Column="4"
                                               FontFamily="Hanken Grotesk" FontSize="11" Foreground="#64748B" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- DataGrid -->
                            <Border Grid.Row="3" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Margin="16,6,16,0">
                                <DataGrid x:Name="blocks_grid"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          Background="White" BorderThickness="0"
                                          AlternatingRowBackground="#F8FAFC" FontFamily="Hanken Grotesk" FontSize="12" Foreground="#27272A"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F1F5F9" SelectionMode="Single"
                                          VerticalScrollBarVisibility="Auto">

                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background"      Value="#FFFFFF"/>
                                            <Setter Property="Foreground"      Value="#9A9AA2"/>
                                            <Setter Property="FontWeight"      Value="Bold"/>
                                            <Setter Property="FontSize"        Value="11"/>
                                            <Setter Property="Padding"         Value="10,8"/>
                                            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Height"          Value="34"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F1F5F9"/></Trigger>
                                                <Trigger Property="IsSelected"  Value="True"><Setter Property="Background" Value="#E2E8F0"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="&#x2713;" Width="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Block Name"   Binding="{Binding BlockName}"    Width="*"   IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Layer/Level"  Binding="{Binding LayerLevel}"   Width="110" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Curves"       Binding="{Binding CurveCount}"   Width="60"  IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Instances"    Binding="{Binding InstanceCount}" Width="70" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Width (mm)"  Binding="{Binding WidthMM}"      Width="82"  IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Depth (mm)"  Binding="{Binding DepthMM}"      Width="82"  IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Arcs"         Binding="{Binding ArcCount}"    Width="52"  IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Foreground" Value="#64748B"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- CAD Action bar -->
                            <Border Grid.Row="4" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="16,10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Content="Select All"   Style="{StaticResource SecondaryButton}" Click="select_all_clicked"   Margin="0,0,8,0"/>
                                        <Button Content="Deselect All" Style="{StaticResource SecondaryButton}" Click="deselect_all_clicked"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <CheckBox x:Name="batch_skip_existing" Content="Skip existing"
                                                  Style="{StaticResource T3CheckBox}" Margin="0,0,16,0"
                                                  ToolTip="Skip presets that already have a matching .rfa file"/>
                                        <CheckBox x:Name="chk_load_to_project" Content="Load to Project"
                                                  Style="{StaticResource T3CheckBox}" Margin="0,0,16,0"
                                                  ToolTip="After export, load each family into the current Revit project"/>
                                        <Button x:Name="btn_presets" Content="Presets"
                                                Style="{StaticResource AccentButton}" Click="presets_clicked"
                                                Padding="16,8" FontSize="13" Margin="0,0,8,0"
                                                ToolTip="Generate standard parametric families from built-in presets (uses Category and Output folder above)"/>
                                        <Button x:Name="btn_export_and_place" Content="Export &amp; Place"
                                                Style="{StaticResource PrimaryButton}" Click="export_and_place_clicked"
                                                Padding="16,8" FontSize="13" Margin="0,0,8,0"
                                                ToolTip="Export each selected block as .rfa and place every CAD instance at its exact world-space position"/>
                                        <Button x:Name="btn_export" Content="Export Selected"
                                                Style="{StaticResource SuccessButton}" Click="export_clicked"
                                                Padding="20,8" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ─── PANEL: FROM JSON ─── -->
                    <Grid x:Name="panel_json" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Tip -->
                            <RowDefinition Height="*"/>     <!-- JSON editor -->
                            <RowDefinition Height="Auto"/>  <!-- Action bar -->
                        </Grid.RowDefinitions>

                        <!-- Tip -->
                        <Border Grid.Row="0" Margin="16,12,16,0" Background="#F4F4F6" BorderBrush="#E6E6EA"
                                BorderThickness="1" CornerRadius="14" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="20" Height="20" CornerRadius="10" Background="#18181B"
                                        VerticalAlignment="Top" Margin="0,1,8,0">
                                    <Path Data="M12 11 V16.5 M12 7.6 V7.62" Stroke="White" StrokeThickness="2.1"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="12" Height="12" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" FontSize="13" Foreground="#3F3F46" TextWrapping="Wrap">
                                    <Run Text="Tip. " FontWeight="Bold" Foreground="#18181B"/>
                                    <Run Text="Pick the Family type (bottom-right) first, then Copy Prompt — the prompt is tailored to that category. Paste the AI's JSON below. Forms: Extrusion · Blend · Revolution · Sweep — curves: Line · Arc · Arc3P · Circle · Ellipse · Spline — voids via inner_loops"/>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- JSON editor -->
                        <TextBox x:Name="json_tb" Grid.Row="1" Margin="16,12,16,6"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="12"
                                 Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                 Padding="12" Text="Paste your JSON schema here..."/>

                        <!-- JSON Action bar -->
                        <Border Grid.Row="2" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="16,10">
                            <Grid>
                                <TextBlock x:Name="lbl_status" Grid.Column="0" Text="Ready"
                                           VerticalAlignment="Center" Foreground="#64748B" FontSize="12" HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Family type" VerticalAlignment="Center"
                                               Foreground="#3F3F46" FontSize="12" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="json_category_combo" Width="180"
                                              Style="{StaticResource T3ComboBoxSmall}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"
                                              ToolTip="Pick the family type first, then Copy Prompt to get a category-tailored prompt."/>
                                    <Button x:Name="copy_prompt_btn" Content="Copy Prompt"
                                            Width="130" Style="{StaticResource SuccessButton}"
                                            Click="copy_prompt_clicked" Margin="0,0,8,0"/>
                                    <Button x:Name="cancel_btn" Content="Cancel"
                                            Width="100" Style="{StaticResource SecondaryButton}"
                                            Click="cancel_clicked" Margin="0,0,8,0"/>
                                    <Button x:Name="create_btn" Content="Create Family"
                                            Width="140" Style="{StaticResource PrimaryButton}"
                                            Click="create_clicked"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══ ROW 2 / COL 1: STATUS BAR                                -->
            <!-- ════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Grid.Column="1" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Status text & Progress -->
                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                        <!-- Progress panel (hidden when idle) -->
                        <Grid x:Name="progress_panel" Visibility="Collapsed" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="52"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar x:Name="pb_export" Grid.Column="0" Style="{StaticResource T3ProgressBar}"
                                         Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center"/>
                            <Button x:Name="btn_pause_export" Grid.Column="2"
                                    Content="⏸  Pause" Height="22" FontSize="10" FontFamily="Hanken Grotesk"
                                    Click="pause_resume_clicked" Cursor="Hand"
                                    BorderThickness="1" BorderBrush="#CBD5E1" VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#0F172A"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="6,2">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F1F5F9"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="btn_stop_export" Grid.Column="4"
                                    Content="■  Stop" Height="22" FontSize="10" FontFamily="Hanken Grotesk"
                                    Click="stop_export_clicked" Cursor="Hand"
                                    BorderThickness="0" VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#EF4444"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,2">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#DC2626"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="© Copyright by T3Lab" FontSize="11" Foreground="#F59E0B" VerticalAlignment="Center"/>
                            <Border Width="1" Height="14" Background="#DCDCE0" Margin="12,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="status_text" FontSize="11" Foreground="#64748B" Text="Ready" VerticalAlignment="Center"/>
                            <TextBlock x:Name="block_count_text" FontSize="11" Foreground="#64748B" Text="" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
