        <Style x:Key="T3ProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#ECECEF"/>
            <Setter Property="Foreground" Value="#C2410C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="BackgroundBorder" Background="{TemplateBinding Background}" CornerRadius="4"/>
