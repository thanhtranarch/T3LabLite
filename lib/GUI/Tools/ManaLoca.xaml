    <!-- ═══ Outer Border: CornerRadius + ClipToBounds (Lumina standard) ═══ -->
    <Border BorderBrush="#A1A1AA" BorderThickness="1.5" CornerRadius="22" ClipToBounds="True" Background="#E4E4E7">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="66"/>    <!-- Col 0: Left Sidebar Icon Rail -->
                <ColumnDefinition Width="*"/>     <!-- Col 1: Main content area -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>      <!-- Row 0: Title bar -->
                <RowDefinition Height="48"/>      <!-- Row 1: Toolbar -->
                <RowDefinition Height="*"/>       <!-- Row 2: Content -->
                <RowDefinition Height="32"/>      <!-- Row 3: Status bar -->
            </Grid.RowDefinitions>

            <!-- COL 0: LEFT SIDEBAR ICON RAIL (spans all rows) -->
            <Border Grid.Column="0" Grid.RowSpan="4"
                    Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,0,1,0">
                <Grid Margin="0,16,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Logo -->
                        <RowDefinition Height="Auto"/> <!-- Current View -->
                        <RowDefinition Height="Auto"/> <!-- By Level -->
                        <RowDefinition Height="*"/>    <!-- Spacer -->
                    </Grid.RowDefinitions>

                    <!-- Logo: Location pin -->
                    <Border Grid.Row="0" Width="42" Height="42" CornerRadius="13"
                            Background="White" BorderBrush="#DCDCE0" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Path Data="M12 2 C8 2 4 6 4 10 C4 16 12 22 12 22 C12 22 20 16 20 10 C20 6 16 2 12 2 Z M12 13 A3 3 0 1 1 12 7 A3 3 0 1 1 12 13 Z"
                              Stroke="#18181B" StrokeThickness="1.6" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="18" Height="18" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Tab: Current View -->
                    <RadioButton x:Name="rb_current_view" Grid.Row="1"
                                 GroupName="SourceMode"
                                 Style="{StaticResource T3SidebarRadio}"
                                 Margin="0,0,0,8" IsChecked="True" Checked="mode_changed"
                                 ToolTip="Current View: Load all elements from the active view">
                        <Path Data="M4 7 H20 M4 12 H20 M4 17 H20"
                              Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                              StrokeThickness="1.8" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="17" Height="17" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </RadioButton>

                    <!-- Tab: By Level -->
                    <RadioButton x:Name="rb_by_level" Grid.Row="2"
                                 GroupName="SourceMode"
                                 Style="{StaticResource T3SidebarRadio}"
                                 Margin="0,0,0,8" Checked="mode_changed"
                                 ToolTip="By Level: Load elements by level">
                        <Path Data="M4 4 H20 M12 4 V20 M4 12 H20 M4 20 H20"
                              Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                              StrokeThickness="1.8" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="17" Height="17" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </RadioButton>
                </Grid>
            </Border>

            <!-- COL 1, ROW 0: TITLE BAR (64px, #F4F4F6) -->
            <Grid Grid.Column="1" Grid.Row="0" Background="#F4F4F6" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="20,0,0,0" VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="Location Manager"
                               FontSize="15" FontWeight="Bold" Foreground="#18181B"/>
                    <TextBlock Text="Review &amp; adjust element positions"
                               FontSize="12.5" Foreground="#71717A" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Search pill in title bar -->
                <Border Grid.Column="1" Width="280" Height="34"
                        Background="White" BorderBrush="#DCDCE0" BorderThickness="1"
                        CornerRadius="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="12,0,12,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="M11 4 A7 7 0 1 0 11 18 A7 7 0 1 0 11 4 M21 21 L16.7 16.7"
                              Stroke="#71717A" StrokeThickness="1.9"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="13" Height="13" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="txt_search"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="13" Foreground="#27272A"
                                     VerticalContentAlignment="Center"
                                     TextChanged="search_changed"/>
                            <TextBlock Text="Search by category, type, level or ID…"
                                       FontSize="13" Foreground="#71717A"
                                       VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=txt_search}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,8,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="btn_minimize" WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource WinCtrlButton}"
                            Click="minimize_button_clicked" ToolTip="Minimize">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="btn_maximize" WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource WinCtrlButton}"
                            Click="maximize_button_clicked" ToolTip="Maximize">
                        <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="btn_close" WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource CloseButton}"
                            Click="close_button_clicked" ToolTip="Close">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>

                <Border Height="1" VerticalAlignment="Bottom" Background="#DCDCE0" Grid.ColumnSpan="3"/>
            </Grid>

            <!-- COL 1, ROW 1: TOOLBAR — source mode + actions -->
            <Border Grid.Column="1" Grid.Row="1" Background="#F8FAFC" BorderBrush="#DCDCE0"
                    BorderThickness="0,0,0,1" Padding="14,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                        <Button x:Name="btn_refresh" Content="Refresh"
                                Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,4,0"
                                Click="refresh_clicked"
                                ToolTip="Reload elements for the current source mode"/>
                        <Button x:Name="btn_get_sel" Content="Get Selection"
                                Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,4,0"
                                Click="get_selection_clicked"
                                ToolTip="Load currently selected elements in Revit"/>
                        <Button x:Name="btn_pick" Content="Pick Elements"
                                Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,4,0"
                                Click="pick_elements_clicked"
                                ToolTip="Pick elements directly from Revit canvas"/>
                        <Button x:Name="btn_sync_sel" Content="Sync Selection"
                                Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,4,0"
                                Click="sync_selection_clicked"
                                ToolTip="Select highlighted rows in Revit"/>

                        <Rectangle Width="1" Fill="#E2E8F0" Margin="6,8,8,8" VerticalAlignment="Stretch"/>

                        <Button x:Name="btn_round_5mm" Content="Round 5mm"
                                Style="{StaticResource PrimaryButton}" Height="32" Margin="0,0,4,0"
                                Click="round_to_5mm_clicked"
                                ToolTip="Round coordinates to nearest 5mm (selected rows, or all if none)"/>
                        <Button x:Name="btn_override_odd" Content="Override Odd"
                                Style="{StaticResource DangerButton}" Height="32" Margin="0,0,4,0"
                                Click="override_odd_clicked"
                                ToolTip="Highlight elements with non-integer mm coordinates — red fill"/>
                        <Button x:Name="btn_clear_override" Content="Clear Override"
                                Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,0,0"
                                Click="clear_overrides_clicked"
                                ToolTip="Remove graphic overrides from all loaded elements"/>

                        <Rectangle Width="1" Fill="#E2E8F0" Margin="6,8,8,8" VerticalAlignment="Stretch"
                                   Visibility="{Binding Visibility, ElementName=cmb_level}"/>

                        <ComboBox x:Name="cmb_level"
                                  DisplayMemberPath="Name"
                                  Visibility="Collapsed"
                                  Style="{StaticResource T3ComboBoxSmall}"
                                  Width="160"
                                  Height="32"
                                  Margin="0,0,0,0" VerticalAlignment="Center"
                                  SelectionChanged="level_selection_changed"
                                  ToolTip="Select a level to load elements from"/>
                    </WrapPanel>

                    <Button Grid.Column="2" x:Name="btn_apply" Content="Apply Changes"
                            Style="{StaticResource SuccessButton}" Height="32"
                            Click="apply_clicked" ToolTip="Move elements to edited coordinates"/>
                </Grid>
            </Border>

            <!-- COL 1, ROW 2: CONTENT — category filter + datagrid -->
            <Grid Grid.Column="1" Grid.Row="2" Margin="14,12,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" MinWidth="130" MaxWidth="250"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Category Filter Panel -->
                <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="12" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1" Padding="10,8"
                                CornerRadius="12,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CATEGORIES" FontSize="10"
                                           FontWeight="SemiBold" Foreground="#64748B"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="btn_select_all_cats" Content="All"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="24" Padding="8,0" FontSize="10"
                                            Click="select_all_categories_clicked"
                                            ToolTip="Show all categories"/>
                                    <Button x:Name="btn_clear_cats" Content="None"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="24" Padding="8,0" FontSize="10"
                                            Margin="4,0,0,0"
                                            Click="clear_all_categories_clicked"
                                            ToolTip="Hide all categories"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
                            <ListBox x:Name="lst_categories"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ItemContainerStyle="{StaticResource CategoryListItem}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked}"
                                                  Style="{StaticResource T3CheckBox}"
                                                  Click="category_filter_changed"
                                                  Cursor="Hand" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="11"
                                                           Foreground="#0F172A" VerticalAlignment="Center"
                                                           MaxWidth="100" TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Name}"/>
                                                <TextBlock Text="{Binding CountText}" FontSize="10"
                                                           Foreground="#64748B" Margin="4,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                              Background="Transparent" Cursor="SizeWE" Margin="0,2"/>

                <!-- RIGHT: DataGrid in white rounded card -->
                <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="12" ClipToBounds="True">
                    <Grid>
                        <DataGrid x:Name="elem_datagrid"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" SelectionMode="Extended"
                                  IsReadOnly="False"
                                  SelectionChanged="datagrid_selection_changed"
                                  Background="White" BorderThickness="0"
                                  AlternatingRowBackground="#F8FAFC"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F1F5F9"
                                  FontFamily="Hanken Grotesk" FontSize="12"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FFFFFF"/>
                                    <Setter Property="Foreground" Value="#9A9AA2"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="Height" Value="34"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E2E8F0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="ID" Width="90" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="4,0" VerticalAlignment="Center"
                                                       Foreground="#3B82F6" Cursor="Hand">
                                                <Hyperlink Click="id_clicked">
                                                    <Run Text="{Binding Id}"/>
                                                </Hyperlink>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Category"    Binding="{Binding Category}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Type / Name" Binding="{Binding Type}"     Width="*"   IsReadOnly="True"/>
                                <DataGridTextColumn Header="Level"       Binding="{Binding Level}"    Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="X (mm)"      Binding="{Binding X, StringFormat={}{0:F2}, Mode=TwoWay}" Width="110"/>
                                <DataGridTextColumn Header="Y (mm)"      Binding="{Binding Y, StringFormat={}{0:F2}, Mode=TwoWay}" Width="110"/>
                                <DataGridTextColumn Header="Z (mm)"      Binding="{Binding Z, StringFormat={}{0:F2}, Mode=TwoWay}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- COL 1, ROW 3: STATUS BAR (32px, #F4F4F6) -->
            <Border Grid.Column="1" Grid.Row="3" Background="#F4F4F6" BorderBrush="#DCDCE0"
                    BorderThickness="0,1,0,0" Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="© Copyright by T3Lab"
                                   FontSize="11" Foreground="#F59E0B"
                                   VerticalAlignment="Center"/>
                        <Border Width="1" Height="14"
                                Background="#DCDCE0" VerticalAlignment="Center"
                                Margin="12,0,12,0"/>
                        <TextBlock x:Name="status_text"
                                   Text="Ready"
                                   FontSize="12.5" Foreground="#71717A"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" x:Name="status_count"
                               Text="0 elements"
                               FontSize="12.5" Foreground="#71717A"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>