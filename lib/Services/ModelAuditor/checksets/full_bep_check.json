{
  "description": "Comprehensive check combining Project Settings, Naming Convention, Model Performance, and Element Quality rules", 
  "name": "Full BEP Compliance Check", 
  "rules": [
    {
      "description": "Check Revit version", 
      "name": "Revit Version", 
      "id": "PS_001", 
      "severity": "warning", 
      "params": {
        "expected_version": "2024"
      }, 
      "category": "Project Settings", 
      "type": "value_match", 
      "enabled": false
    }, 
    {
      "description": "Check required Project Information fields", 
      "name": "Project Info Required Fields", 
      "id": "PS_002", 
      "severity": "error", 
      "params": {
        "fields": [
          "Project Name", 
          "Project Number", 
          "Client Name", 
          "Project Address"
        ]
      }, 
      "category": "Project Settings", 
      "type": "not_empty", 
      "enabled": false
    }, 
    {
      "description": "Survey Point N/S coordinate", 
      "name": "Survey Point N/S", 
      "id": "PS_003", 
      "severity": "error", 
      "params": {
        "point_type": "survey", 
        "axis": "NS", 
        "expected_value": 0.0, 
        "tolerance": 0.001
      }, 
      "category": "Project Settings", 
      "type": "coordinate_match", 
      "enabled": false
    }, 
    {
      "description": "Survey Point E/W coordinate", 
      "name": "Survey Point E/W", 
      "id": "PS_004", 
      "severity": "error", 
      "params": {
        "point_type": "survey", 
        "axis": "EW", 
        "expected_value": 0.0, 
        "tolerance": 0.001
      }, 
      "category": "Project Settings", 
      "type": "coordinate_match", 
      "enabled": false
    }, 
    {
      "description": "Check Starting View is set", 
      "name": "Starting View", 
      "id": "PS_005", 
      "severity": "warning", 
      "params": {
        "target": "starting_view"
      }, 
      "category": "Project Settings", 
      "type": "exists_check", 
      "enabled": false
    }, 
    {
      "description": "No Design Options before submission", 
      "name": "Design Options", 
      "id": "PS_006", 
      "severity": "error", 
      "params": {
        "message_over": "Resolve Design Options", 
        "target": "design_options", 
        "max_count": 0
      }, 
      "category": "Project Settings", 
      "type": "count_check", 
      "enabled": false
    }, 
    {
      "description": "Report True North angle", 
      "name": "True North", 
      "id": "PS_007", 
      "severity": "info", 
      "params": {
        "report_only": true, 
        "target": "true_north", 
        "expected_value": 0.0, 
        "tolerance": 0.01
      }, 
      "category": "Project Settings", 
      "type": "value_match_numeric", 
      "enabled": false
    }, 
    {
      "description": "Check view naming pattern", 
      "name": "View Naming", 
      "id": "NC_001", 
      "severity": "warning", 
      "params": {
        "pattern": "^[A-Z].*", 
        "target": "views", 
        "description": "Start with uppercase", 
        "exclude_templates": true
      }, 
      "category": "Naming Convention", 
      "type": "element_naming", 
      "enabled": true
    }, 
    {
      "description": "Check sheet number pattern", 
      "name": "Sheet Numbering", 
      "id": "NC_002", 
      "severity": "warning", 
      "params": {
        "pattern": "^[A-Z]{1,3}[-][0-9]+.*$", 
        "target": "sheets", 
        "description": "DISC-Number format"
      }, 
      "category": "Naming Convention", 
      "type": "element_naming", 
      "enabled": false
    }, 
    {
      "description": "Check level naming pattern", 
      "name": "Level Naming", 
      "id": "NC_003", 
      "severity": "warning", 
      "params": {
        "pattern": "^(B[0-9]+|L[0-9]+|Level [0-9]+|Roof|Ground|Basement).*$", 
        "target": "levels", 
        "description": "Standard level names"
      }, 
      "category": "Naming Convention", 
      "type": "element_naming", 
      "enabled": false
    }, 
    {
      "description": "Check grid naming pattern", 
      "name": "Grid Naming", 
      "id": "NC_004", 
      "severity": "info", 
      "params": {
        "pattern": "^[A-Z]{1,2}$|^[0-9]{1,3}$", 
        "target": "grids", 
        "description": "A, B, 1, 2"
      }, 
      "category": "Naming Convention", 
      "type": "element_naming", 
      "enabled": false
    }, 
    {
      "description": "Check file size", 
      "name": "File Size", 
      "id": "MP_001", 
      "severity": "warning", 
      "params": {
        "max_size_mb": 300
      }, 
      "category": "Model Performance", 
      "type": "file_size", 
      "enabled": false
    }, 
    {
      "description": "Check warning count with grouped summary", 
      "name": "Warnings", 
      "id": "MP_002", 
      "severity": "warning", 
      "params": {
        "max_count": 100
      }, 
      "category": "Model Performance", 
      "type": "warning_count", 
      "enabled": false
    }, 
    {
      "description": "Detect imported CAD files", 
      "name": "CAD Imports", 
      "id": "MP_003", 
      "severity": "error", 
      "params": {
        "check_type": "imported", 
        "max_count": 0
      }, 
      "category": "Model Performance", 
      "type": "cad_import_check", 
      "enabled": false
    }, 
    {
      "description": "Detect In-Place families", 
      "name": "In-Place Families", 
      "id": "MP_004", 
      "severity": "warning", 
      "params": {
        "max_count": 5
      }, 
      "category": "Model Performance", 
      "type": "inplace_family_check", 
      "enabled": false
    }, 
    {
      "description": "Check Revit links", 
      "name": "RVT Links", 
      "id": "MP_005", 
      "severity": "warning", 
      "params": {
        "check_loaded": true, 
        "max_count": 20
      }, 
      "category": "Model Performance", 
      "type": "rvt_link_check", 
      "enabled": false
    }, 
    {
      "description": "Check group types count", 
      "name": "Groups", 
      "id": "MP_006", 
      "severity": "warning", 
      "params": {
        "max_count": 20
      }, 
      "category": "Model Performance", 
      "type": "group_check", 
      "enabled": false
    }, 
    {
      "description": "Detect unplaced rooms", 
      "name": "Unplaced Rooms", 
      "id": "EQ_001", 
      "severity": "warning", 
      "params": {
        "max_count": 0
      }, 
      "category": "Element Quality", 
      "type": "unplaced_rooms", 
      "enabled": false
    }, 
    {
      "description": "Rooms with very small area", 
      "name": "Small Rooms", 
      "id": "EQ_002", 
      "severity": "warning", 
      "params": {
        "min_area_sqm": 0.5
      }, 
      "category": "Element Quality", 
      "type": "room_area_check", 
      "enabled": false
    }, 
    {
      "description": "Check duplicate Mark values in Doors", 
      "name": "Duplicate Door Marks", 
      "id": "EQ_003", 
      "severity": "warning", 
      "params": {
        "built_in_category": "OST_Doors", 
        "category": "Doors", 
        "ignore_empty": true
      }, 
      "category": "Element Quality", 
      "type": "duplicate_mark", 
      "enabled": false
    }
  ], 
  "created": "2026-03-05 18:02:25", 
  "modified": "2026-03-05 18:02:42", 
  "version": "2.0", 
  "author": "DQT"
}