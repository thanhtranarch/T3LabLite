                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="20" Height="20" CornerRadius="10" Background="#22A85C" VerticalAlignment="Top" Margin="0,1,8,0">
                                    <Path Data="M5 12 L9.5 16.5 L19 7" Stroke="White" StrokeThickness="2.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Width="11" Height="11" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                 <TextBlock Grid.Column="1" FontSize="14" Foreground="#1B7A45" TextWrapping="Wrap">
                                     <Run Text="24 sheets renumbered. " FontWeight="Bold" Foreground="#157038"/>
                                     <Run Text="All views now follow the standard."/>
                                 </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Expander -->
                        <TextBlock Text="EXPANDER" FontSize="11" FontWeight="Bold" Foreground="#9A9AA2" Margin="1,0,0,6"/>
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14" Margin="0,0,0,16">
                            <Expander Header="Advanced layout settings" Background="Transparent" BorderThickness="0" Padding="12,8">
                                <StackPanel>
                                    <CheckBox Style="{StaticResource T3ToggleSwitch}" Content="Auto-tag new callouts" IsChecked="True" Margin="0,4,0,8"/>
                                    <Border Height="1" Background="#F4F4F6" Margin="0,4"/>
                                    <CheckBox Style="{StaticResource T3ToggleSwitch}" Content="Snap to layout grid" IsChecked="False" Margin="0,8,0,4"/>
                                </StackPanel>
                            </Expander>
                        </Border>

                        <!-- Progress -->
                        <TextBlock Text="PROGRESS" FontSize="11" FontWeight="Bold" Foreground="#9A9AA2" Margin="1,0,0,6"/>
                        <StackPanel Margin="0,0,0,16">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Exporting audit to Excel…" FontSize="12.5" Foreground="#71717A"/>
                                <TextBlock Text="75%" HorizontalAlignment="Right" FontSize="12.5" FontWeight="SemiBold" Foreground="#C2410C"/>
                            </Grid>
                            <ProgressBar Value="75" Height="8" Background="#ECECEF" Foreground="#C2410C" BorderThickness="0"/>
                        </StackPanel>

                        <!-- Slider -->
                        <TextBlock Text="SLIDER" FontSize="11" FontWeight="Bold" Foreground="#9A9AA2" Margin="1,0,0,6"/>
                        <StackPanel Margin="0,0,0,4">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Slider" FontSize="12.5" Foreground="#71717A"/>
                                <TextBlock Text="60%" HorizontalAlignment="Right" FontSize="12.5" FontWeight="SemiBold" Foreground="#C2410C"/>
                            </Grid>
                            <Slider Style="{StaticResource T3Slider}" Minimum="0" Maximum="100" Value="60"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Data Panel (Table Grid and Tab selection) -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="20" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Tab Selection -->
                        <RowDefinition Height="Auto"/> <!-- Search and Table Actions -->
                        <RowDefinition Height="*"/>    <!-- DataGrid -->
                    </Grid.RowDefinitions>

                    <!-- Top Navigation Tab Selection Simulator (styled like gray pills) -->
                    <Border Grid.Row="0" Margin="0,0,0,16" HorizontalAlignment="Left">
                        <Border Background="#F4F4F6" CornerRadius="18" Padding="4" Height="36" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="White" CornerRadius="14" Padding="12,6" SnapsToDevicePixels="True">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Active View List" FontSize="13.5" FontWeight="SemiBold" Foreground="#18181B"/>
                                        <Border Background="#18181B" CornerRadius="9" MinWidth="18" Height="18" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="9" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Background="Transparent" Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Archived Log" FontSize="13.5" FontWeight="Medium" Foreground="#71717A"/>
                                        <Border Background="#DCDCE0" CornerRadius="9" MinWidth="18" Height="18" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="6" FontSize="11" FontWeight="Bold" Foreground="#71717A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border Background="Transparent" Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Configuration Rules" FontSize="13.5" FontWeight="Medium" Foreground="#71717A"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Search and Table Action Filters -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="260" Height="36" Background="#F4F4F6" BorderBrush="#E6E6EA" BorderThickness="1" CornerRadius="18" Padding="10,0,10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="M11 4 A7 7 0 1 0 11 18 A7 7 0 1 0 11 4 M21 21 L16.7 16.7" 
                                          Stroke="#71717A" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource T3InputField}" Text="" Tag="Search views, IDs, categories…" Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Center" Height="24" FontSize="13.5"/>
                                </Grid>
                            </Border>

                            <Border Background="#F4F4F6" CornerRadius="15" Padding="3" Margin="12,0,0,0" Height="30" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="White" CornerRadius="12" Padding="10,3">
                                        <TextBlock Text="All views" FontSize="12.5" FontWeight="SemiBold" Foreground="#18181B"/>
                                    </Border>
                                    <Border Background="Transparent" Padding="10,3">
                                        <TextBlock Text="Compliant" FontSize="12.5" Foreground="#71717A"/>
                                    </Border>
                                    <Border Background="Transparent" Padding="10,3">
                                        <TextBlock Text="Issues" FontSize="12.5" Foreground="#71717A"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="12 views" VerticalAlignment="Center" FontSize="13.5" Foreground="#71717A" FontWeight="SemiBold" Margin="0,0,12,0"/>
                            <Border Background="#18181B" CornerRadius="10" Height="20" Padding="8,0" VerticalAlignment="Center">
                                <TextBlock Text="3 selected" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- DataGrid standard style -->
                    <DataGrid x:Name="sample_grid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                               SelectionMode="Extended" SelectionUnit="FullRow" CanUserSortColumns="True"
                               Background="White" BorderBrush="#E2E8F0" BorderThickness="1" GridLinesVisibility="Horizontal"
                               HorizontalGridLinesBrush="#F1F5F9" RowBackground="White" AlternatingRowBackground="#F8FAFC"
                               FontFamily="Hanken Grotesk" FontSize="13.5" Foreground="#27272A">
                        <DataGrid.Resources>
                            <!-- Table Header Style -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Element ID" Binding="{Binding id}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="JetBrains Mono"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Foreground" Value="#71717A"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Name" Binding="{Binding name}" Width="220"/>
                            <DataGridTextColumn Header="Standard Category" Binding="{Binding category}" Width="150"/>
                            <DataGridTemplateColumn Header="Compliance Status" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="statusPill"
                                                CornerRadius="10"
                                                Padding="11,4,9,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse x:Name="statusDot"
                                                         Width="7" Height="7"
                                                         Margin="0,0,7,0"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock x:Name="statusText"
                                                           Text="{Binding status}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding status}" Value="Compliant">
                                                <Setter TargetName="statusPill" Property="Background" Value="#0F8A66"/>
                                                <Setter TargetName="statusDot" Property="Fill" Value="#B6F2D8"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding status}" Value="Non-Compliant (Template missing)">
                                                <Setter TargetName="statusPill" Property="Background" Value="#1F1F23"/>
                                                <Setter TargetName="statusDot" Property="Fill" Value="#F87171"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding status}" Value="Non-Compliant (Naming standard)">
                                                <Setter TargetName="statusPill" Property="Background" Value="#1F1F23"/>
                                                <Setter TargetName="statusDot" Property="Fill" Value="#F87171"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding status}" Value="Needs Review">
                                                <Setter TargetName="statusPill" Property="Background" Value="#8A6308"/>
                                                <Setter TargetName="statusDot" Property="Fill" Value="#F5CE5A"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ ROW 3: ACTION BUTTONS / FOOTER (Column 1) ═══ -->
        <!-- Footer layout standard: Copyright + Status together on the LEFT, all action buttons on the RIGHT -->
        <Border Grid.Row="3" Grid.Column="1" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Copyright, then Status right beside it -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="© Copyright by T3Lab" FontSize="11" Foreground="#F59E0B" VerticalAlignment="Center"/>
                    <Border Width="1" Height="14" Background="#DCDCE0" Margin="12,0,12,0" VerticalAlignment="Center"/>
                    <Ellipse Width="8" Height="8" Fill="#22A85C" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="System status: " FontSize="13.5" Foreground="#27272A" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="Fully compliant" FontSize="13.5" Foreground="#157038" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: all action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Button Style="{StaticResource GhostButton}" Margin="0,0,8,0" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M4 7 h16 M9.5 7 V5 H14.5 V7 M6.5 7 l1 13 A1.5 1.5 0 0 0 9 21.5 h6 a1.5 1.5 0 0 0 1.5-1.5 L17.5 7"
                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Delete" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource TertiaryButton}" Margin="0,0,8,0" Padding="16,9">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M5 12 L9.5 16.5 L19 7"
                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Approve" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="16,9">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M4 8 h9 M17 8 h3 M4 16 h3 M11 16 h9"
                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Configure" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="16,9">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 4 V14 M8 11 L12 15 L16 11 M5 19 H19"
                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Export" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource PrimaryButton}" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M8 5 L18 12 L8 19 Z" Fill="White" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Run check" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        </Grid>
    </Border>
</Window>
