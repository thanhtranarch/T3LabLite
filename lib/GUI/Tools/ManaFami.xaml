<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ManaFami"
        Width="1100" Height="700"
        MinWidth="950" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#E4E4E7"
        FontFamily="Hanken Grotesk">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="22"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ═══ T3LAB SHARED STYLES v2 — AUTO-SYNCED, DO NOT EDIT (edit lib/GUI/Resources/WPF_styles.xaml, then run dev/sync_wpf_styles.py) ═══ -->
        <!-- Central Color Brushes (Lumina / T3Lab Standard System) -->
        <SolidColorBrush x:Key="T3PrimaryInkBrush" Color="#18181B"/>
        <SolidColorBrush x:Key="T3PrimaryTextBrush" Color="#27272A"/>
        <SolidColorBrush x:Key="T3SecondaryTextBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="T3TertiaryTextBrush" Color="#71717A"/>
        <SolidColorBrush x:Key="T3DisabledBorderBrush" Color="#9A9AA2"/>
        <SolidColorBrush x:Key="T3MainAppBgBrush" Color="#E4E4E7"/>
        <SolidColorBrush x:Key="T3ComponentBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="T3InputFieldBgBrush" Color="#F4F4F6"/>
        
        <!-- Semantic & Status Brushes -->
        <SolidColorBrush x:Key="T3SuccessBgBrush" Color="#EAF8F0"/>
        <SolidColorBrush x:Key="T3SuccessTextBrush" Color="#157038"/>
        <SolidColorBrush x:Key="T3SuccessBorderBrush" Color="#09734B"/>
        <SolidColorBrush x:Key="T3SuccessAccentBrush" Color="#0B8A5A"/>
        
        <SolidColorBrush x:Key="T3WarningBgBrush" Color="#FFF6E6"/>
        <SolidColorBrush x:Key="T3WarningTextBrush" Color="#8A6308"/>
        <SolidColorBrush x:Key="T3WarningAccentBrush" Color="#F5CE5A"/>
        
        <SolidColorBrush x:Key="T3DangerBgBrush" Color="#FDECEC"/>
        <SolidColorBrush x:Key="T3DangerTextBrush" Color="#D23B3B"/>
        <SolidColorBrush x:Key="T3DangerAccentBrush" Color="#F87171"/>
        
        <SolidColorBrush x:Key="T3ProgressActionBrush" Color="#C2410C"/>

        <!-- TERTIARY BUTTON - soft gray background, dark text -->
        <Style x:Key="TertiaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#ECECEF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E2E6"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#ECECEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sleek Modern ComboBox -->
        <Style x:Key="T3ComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Content -->
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                                      
                                    <!-- Toggle Button (Arrow) -->
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    
                                    <!-- Arrow Icon -->
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="12" Height="12"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            
                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="true"
                                   IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="13"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Toggle Switch Style (CheckBox) -->
        <Style x:Key="T3ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="0" 
                                              Focusable="False" 
                                              HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                              
                            <!-- Toggle Track -->
                            <Border x:Name="toggleTrack" 
                                    Grid.Column="1"
                                    Width="42" Height="24"
                                    Background="#DCDCE2"
                                    CornerRadius="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <!-- Toggle Knob -->
                                <Ellipse x:Name="toggleKnob"
                                         Width="20" Height="20"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="2,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="1" Direction="270" Color="Black" Opacity="0.15" BlurRadius="2"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#18181B"/>
                                <Setter TargetName="toggleKnob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="toggleTrack" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="toggleKnob" Property="Fill" Value="#9A9AA2"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Slider -->
        <Style x:Key="T3Slider" TargetType="Slider">
            <Setter Property="Background" Value="#E4E4E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Border x:Name="TrackBackground"
                                    Grid.Row="1"
                                    Height="6"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"/>
                                    
                            <!-- Track Fill and Thumb -->
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="#C2410C" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="18" Height="18"
                                                         Fill="White"
                                                         Stroke="#C2410C"
                                                         StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="2" Direction="270" Color="#C2410C" Opacity="0.3" BlurRadius="4"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field -->
        <Style x:Key="T3InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Modern GroupBox Card -->
        <Style x:Key="T3PremiumCard" TargetType="GroupBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Card Header -->
                                <Border Grid.Row="0" 
                                        Background="#FFFFFF"
                                        Padding="16,12"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter ContentSource="Header"
                                                      TextBlock.FontSize="14"
                                                      TextBlock.FontWeight="Bold"
                                                      TextBlock.Foreground="#18181B"
                                                      TextBlock.FontFamily="Hanken Grotesk"/>
                                </Border>
                                <!-- Card Content -->
                                <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Top Navigation Tab Style -->
        <Style x:Key="T3TopNavTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#18181B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON - solid deep slate, white text -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#18181B"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F4F4F6"/>
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SECONDARY BUTTON - white background, border and text slate -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#27272A"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="13.5"/>
            <Setter Property="FontFamily"      Value="Hanken Grotesk"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#DEDEE2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFB"/>
                    <Setter Property="BorderBrush" Value="#CFCFD5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#9A9AA2"/>
                    <Setter Property="BorderBrush" Value="#E6E6EA"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GHOST BUTTON -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#52525B"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EDEDEF"/>
                    <Setter Property="Foreground" Value="#18181B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E2E2E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SUCCESS BUTTON -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#0B8A5A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#09734B"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0B8A5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#D23B3B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F87171"/>
                    <Setter Property="Foreground" Value="#1F1F23"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ACCENT BUTTON -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#18181B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Icon Button Style -->
        <Style x:Key="T3SidebarButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F4F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- WINDOW CONTROL BUTTON -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#18181B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E4E4E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CLOSE BUTTON -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D23B3B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Premium CheckBox Style -->
        <Style x:Key="T3CheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBoxBorder" 
                                    Grid.Column="0"
                                    Width="18" Height="18"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="1.5"
                                    Background="White"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Path x:Name="optionMark" 
                                      Data="M4,9 L8,13 L14,5" 
                                      Stroke="White" 
                                      StrokeThickness="2" 
                                      StrokeStartLineCap="Round" 
                                      StrokeEndLineCap="Round" 
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#18181B"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="optionMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium RadioButton Style -->
        <Style x:Key="T3RadioButton" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="radioBorder" 
                                    Grid.Column="0"
                                    Width="20" Height="20"
                                    Margin="0,0,8,0"
                                    BorderBrush="#D4D4DA"
                                    BorderThickness="2"
                                    Background="White"
                                    CornerRadius="10"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Ellipse x:Name="radioDot"
                                         Width="9" Height="9"
                                         Fill="#18181B"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Grid.Column="1" 
                                              Focusable="False" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                                <Setter TargetName="radioDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="radioBorder" Property="Background" Value="#F4F4F6"/>
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#9A9AA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Scrollbar Styling -->
        <Style TargetType="{x:Type Thumb}" x:Key="ScrollBarThumbStyle">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="thumbBorder" Background="#A1A1AA" CornerRadius="2" Margin="0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#71717A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="true"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="false"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="4"/>
                    <Setter Property="Height" Value="Auto"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- SIDEBAR TOGGLE BUTTON (for icon-only sidebar filter/nav) -->
        <Style x:Key="T3SidebarToggle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717A"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#18181B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#E6E6EA"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#27272A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Sleek Modern ComboBox Small -->
        <Style x:Key="T3ComboBoxSmall" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <Path Grid.Column="1"
                                          Data="M6 9 L12 15 L18 9"
                                          Stroke="#71717A"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Width="10" Height="10"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                    AllowsTransparency="true"
                                    IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    Placement="Bottom"
                                    PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="White"
                                        BorderBrush="#E6E6EA"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern ComboBox Small ToggleButton -->
        <Style x:Key="T3ComboBoxSmallToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  IsHitTestVisible="False"/>
                                <Path Grid.Column="1"
                                      Data="M6 9 L12 15 L18 9"
                                      Stroke="#71717A"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="10" Height="10"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Modern Input Field Small -->
        <Style x:Key="T3InputFieldSmall" TargetType="TextBox">
            <Setter Property="Background" Value="#F4F4F6"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="BorderBrush" Value="#E6E6EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#18181B"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat ProgressBar Style (Lumina Standard) -->
        <Style x:Key="T3ProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#ECECEF"/>
            <Setter Property="Foreground" Value="#C2410C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border x:Name="BackgroundBorder" Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Border x:Name="PART_Track" ClipToBounds="True" CornerRadius="4" Background="Transparent">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="4"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Queue Item ProgressBar Style with complete trigger -->
        <Style x:Key="QueueProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource T3ProgressBar}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Progress}" Value="100">
                    <Setter Property="Foreground" Value="#10B981"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Pill RadioButton Style -->
        <Style x:Key="TabPillRadioButton" TargetType="RadioButton">
            <Setter Property="GroupName" Value="TabPills"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Hanken Grotesk"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#18181B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E2E6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ END T3LAB SHARED STYLES ═══ -->

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="3,2"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#A1A1AA" BorderThickness="1.5" CornerRadius="22" ClipToBounds="True" Background="#E4E4E7">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/> <!-- Sidebar Column 0 -->
                <ColumnDefinition Width="*"/>  <!-- Content Column 1 -->
            </Grid.ColumnDefinitions>

            <!-- COL 0: LEFT SIDEBAR ICON RAIL -->
            <Border Grid.Column="0" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,0,1,0">
                <Grid Margin="0,16,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Logo icon -->
                        <RowDefinition Height="Auto"/>  <!-- Nav: Loader -->
                        <RowDefinition Height="Auto"/>  <!-- Nav: Management -->
                        <RowDefinition Height="*"/>     <!-- Spacer -->
                    </Grid.RowDefinitions>

                    <!-- Tool logo icon: standard family manager icon (nested folders / generic model symbol) -->
                    <Border Grid.Row="0" Width="42" Height="42" CornerRadius="13"
                            Background="White" BorderBrush="#DCDCE0" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Path Data="M3 3 h8 v8 H3 z M13 3 h8 v8 h-8 z M3 13 h8 v8 H3 z M13 13 h8 v8 h-8 z"
                              Stroke="#18181B" StrokeThickness="1.6"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Nav: Family Loader -->
                    <ToggleButton x:Name="nav_loader" Grid.Row="1"
                                  Style="{StaticResource T3SidebarToggle}"
                                  IsChecked="True" Margin="0,0,0,8"
                                  ToolTip="Family Loader" Click="nav_toggle_clicked">
                        <!-- Import/Load icon: folder opening with incoming arrow -->
                        <Path Data="M4 20 h16 a2 2 0 0 0 2-2 V8 a2 2 0 0 0-2-2 h-7.5 L10.5 4 H4 a2 2 0 0 0-2 2 v12 a2 2 0 0 0 2 2 z M12 9 v6 M9 12 l3 3 3-3"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Width="19" Height="19" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ToggleButton>

                    <!-- Nav: Family Management -->
                    <ToggleButton x:Name="nav_management" Grid.Row="2"
                                  Style="{StaticResource T3SidebarToggle}"
                                  Margin="0,0,0,8"
                                  ToolTip="Family Management" Click="nav_toggle_clicked">
                        <!-- Edit/List icon: list of rows with bullet dots and lines -->
                        <Path Data="M3 6 h18 M3 12 h18 M3 18 h18 M3 6 h.01 M3 12 h.01 M3 18 h.01"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Width="19" Height="19" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ToggleButton>
                </Grid>
            </Border>

            <!-- COL 1: MAIN WORKSPACE Grid containing Title Bar, TabControl, and Status Bar -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>       <!-- Title bar -->
                    <RowDefinition Height="*"/>        <!-- Main content (Headerless TabControl) -->
                    <RowDefinition Height="Auto"/>     <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <Grid Grid.Row="0" Background="#F4F4F6" Height="64">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title and Subtitle -->
                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center"
                                Margin="22,0,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock x:Name="lbl_title" Text="ManaFami" FontSize="15" FontWeight="Bold" Foreground="#18181B"/>
                        <TextBlock x:Name="lbl_subtitle" Text="Load families and manage renaming, prefix/suffix, worksets in one central hub" FontSize="12.5" Foreground="#71717A" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Window control buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,5,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="btn_minimize" Style="{StaticResource WinCtrlButton}" ToolTip="Minimize">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                        <Button x:Name="btn_maximize" Style="{StaticResource WinCtrlButton}" ToolTip="Maximize">
                            <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                        <Button x:Name="btn_close_chrome" Style="{StaticResource CloseButton}" ToolTip="Close">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>

                    <!-- Title bar bottom border -->
                    <Border Height="1" VerticalAlignment="Bottom" Background="#DCDCE0" Grid.ColumnSpan="2"/>
                </Grid>

                <!-- TAB CONTROL -->
                <TabControl x:Name="main_tab_control" Grid.Row="1" BorderThickness="0" Background="Transparent" Padding="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/> <!-- Headerless TabControl -->
                        </Style>
                    </TabControl.Resources>

                    <!-- TAB 0: FAMILY LOADER -->
                    <TabItem Header="Loader">
                        <Grid Background="#F8FAFC">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>   <!-- Search bar -->
                                <RowDefinition Height="44"/>   <!-- Folder / source selection -->
                                <RowDefinition Height="*"/>    <!-- Category Tree + Family list WrapPanel -->
                                <RowDefinition Height="62"/>   <!-- Action footer -->
                            </Grid.RowDefinitions>

                            <!-- Search Bar -->
                            <Border Grid.Row="0" Background="White" Padding="14,7" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <Border Height="36" Background="#F4F4F6" BorderBrush="#E6E6EA" BorderThickness="1"
                                        CornerRadius="18" Padding="10,0,10,0" VerticalAlignment="Center">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Grid.Column="0" Data="M11 4 A7 7 0 1 0 11 18 A7 7 0 1 0 11 4 M21 21 L16.7 16.7"
                                              Stroke="#71717A" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="txt_search"
                                                     Background="Transparent" BorderThickness="0" Padding="0"
                                                     VerticalAlignment="Center" VerticalContentAlignment="Center"
                                                     Height="24" FontSize="13" FontFamily="Hanken Grotesk" Foreground="#18181B"/>
                                            <TextBlock Text="Search families…" Foreground="#71717A" FontSize="13" FontFamily="Hanken Grotesk"
                                                       VerticalAlignment="Center" IsHitTestVisible="False">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=txt_search}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Border>

                            <!-- Folder selection -->
                            <Border Grid.Row="1" Background="#F8FAFC" Padding="12,0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <DockPanel VerticalAlignment="Center">
                                    <!-- Path Selection Button + Path Name -->
                                    <Button x:Name="btn_select_folder" Content="Update Folder" Style="{StaticResource SecondaryButton}" Height="28" Padding="10,2" FontSize="11.5" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="txt_current_folder" Text="No folder selected" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11.5" Foreground="#64748B" TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </Border>

                            <!-- Main content: Categories (left) + WrapPanel (right) -->
                            <DockPanel Grid.Row="2">
                                <!-- Categories TreeView -->
                                <Border DockPanel.Dock="Left" Width="200" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0" Background="#F8FAFC">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Top" Background="#F1F5F9" Padding="12,6" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                            <TextBlock Text="Categories" FontSize="11" FontWeight="SemiBold" Foreground="#0F172A"/>
                                        </Border>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TreeView x:Name="tree_categories" BorderThickness="0" Background="Transparent" Padding="4"/>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                                <!-- Grid list of families -->
                                <DockPanel>
                                    <!-- Search result counts & Select All/None -->
                                    <Border DockPanel.Dock="Top" Padding="12,6" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock x:Name="txt_result_count" Text="0 families found" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A" HorizontalAlignment="Left"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="btn_select_all_loader" Content="Select All" Style="{StaticResource SecondaryButton}" Height="28" Padding="10,2" FontSize="11" Margin="0,0,6,0"/>
                                                <Button x:Name="btn_select_none_loader" Content="Select None" Style="{StaticResource SecondaryButton}" Height="28" Padding="10,2" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <!-- WrapPanel families grid -->
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="10">
                                        <ItemsControl x:Name="items_families">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Width="155" Margin="5,5,5,10">
                                                        <Border Height="148" CornerRadius="8" Cursor="Hand" BorderThickness="1" BorderBrush="#E2E8F0" Background="White">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#0F172A"/>
                                                                            <Setter Property="BorderThickness" Value="2"/>
                                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Border Background="#F8FAFC" CornerRadius="7" Margin="1"/>
                                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="10"/>
                                                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="7" Style="{StaticResource T3CheckBox}"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#0F172A" TextWrapping="Wrap" MaxHeight="34" Margin="3,4,3,0" ToolTip="{Binding FullPath}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </DockPanel>

                            <!-- Footer -->
                            <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,10">
                                <Grid>
                                    <TextBlock x:Name="txt_selected_count" Text="0 families selected" VerticalAlignment="Center" FontSize="12" Foreground="#64748B" HorizontalAlignment="Left"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="btn_load" Content="Load" Style="{StaticResource SuccessButton}" Width="110" Height="28" IsEnabled="False" Margin="0,0,8,0"/>
                                        <Button x:Name="btn_cancel_loader" Content="Cancel" Style="{StaticResource SecondaryButton}" Width="90" Height="28"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- TAB 1: FAMILY MANAGEMENT -->
                    <TabItem Header="Management">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/> <!-- Left forms sidebar -->
                                <ColumnDefinition Width="*"/>   <!-- Right grid content -->
                            </Grid.ColumnDefinitions>

                            <!-- LEFT SETTINGS SIDEBAR -->
                            <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0" Background="White">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>      <!-- Scrollable options -->
                                        <RowDefinition Height="Auto"/>   <!-- Clear Settings button -->
                                    </Grid.RowDefinitions>

                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <Border Padding="16,12">
                                            <StackPanel>
                                                <!-- Scope Selector -->
                                                <TextBlock Text="SCOPE" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <StackPanel Margin="0,0,0,14">
                                                    <RadioButton x:Name="rb_scope_all" Content="All Loaded Families" IsChecked="True" Style="{StaticResource T3RadioButton}" Height="24" Checked="scope_changed"/>
                                                    <RadioButton x:Name="rb_scope_view" Content="Active View Only" Style="{StaticResource T3RadioButton}" Height="24" Checked="scope_changed"/>
                                                    <RadioButton x:Name="rb_scope_selection" Content="Currently Selected" Style="{StaticResource T3RadioButton}" Height="24" Checked="scope_changed"/>
                                                </StackPanel>
                                                <Separator Background="#E2E8F0" Margin="0,0,0,12"/>

                                                <!-- Category Selector -->
                                                <TextBlock Text="FAMILIES CATEGORY" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="cb_category" SelectedIndex="0" Style="{StaticResource T3ComboBox}" Height="36" Margin="0,0,0,14" SelectionChanged="category_changed">
                                                    <ComboBoxItem Content="Loadable Families"/>
                                                    <ComboBoxItem Content="System Families"/>
                                                    <ComboBoxItem Content="Model Groups"/>
                                                    <ComboBoxItem Content="Assemblies"/>
                                                </ComboBox>
                                                <Separator Background="#E2E8F0" Margin="0,0,0,12"/>

                                                <!-- Find and Replace -->
                                                <TextBlock Text="FIND AND REPLACE" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                                <TextBlock Text="Find" FontSize="11" Foreground="#0F172A" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="32"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="tb_find" Grid.Column="0" Style="{StaticResource T3InputField}" Height="32"/>
                                                    <ToggleButton x:Name="btn_match_case" Grid.Column="1" Margin="4,0,0,0" ToolTip="Match Case" Click="match_case_click">
                                                        <ToggleButton.Style>
                                                            <Style TargetType="ToggleButton">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                                        <Setter Property="BorderBrush" Value="#3B82F6"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ToggleButton.Style>
                                                        <TextBlock Text="Aa" FontWeight="Bold" FontSize="11" Foreground="#0F172A"/>
                                                    </ToggleButton>
                                                </Grid>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button x:Name="btn_find_next" Grid.Column="0" Content="Find Next" Style="{StaticResource SecondaryButton}" Height="28" Margin="0,0,4,0" FontSize="11"/>
                                                    <Button x:Name="btn_find_all" Grid.Column="1" Content="Find All" Style="{StaticResource SecondaryButton}" Height="28" Margin="4,0,0,0" FontSize="11"/>
                                                </Grid>

                                                <TextBlock Text="Replace with" FontSize="11" Foreground="#0F172A" Margin="0,0,0,4"/>
                                                <TextBox x:Name="tb_replace" Style="{StaticResource T3InputField}" Height="32" Margin="0,0,0,8"/>
                                                <Grid Margin="0,0,0,14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button x:Name="btn_replace" Grid.Column="0" Content="Replace" Style="{StaticResource SecondaryButton}" Height="28" Margin="0,0,4,0" FontSize="11"/>
                                                    <Button x:Name="btn_replace_all" Grid.Column="1" Content="Replace All" Style="{StaticResource SecondaryButton}" Height="28" Margin="4,0,0,0" FontSize="11"/>
                                                </Grid>
                                                <Separator Background="#E2E8F0" Margin="0,0,0,12"/>

                                                <!-- Prefix / Suffix -->
                                                <TextBlock Text="PREFIX / SUFFIX" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                                <TextBlock Text="Prefix" FontSize="11" Foreground="#0F172A" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="tb_prefix" Grid.Column="0" Style="{StaticResource T3InputField}" Height="32"/>
                                                    <Button x:Name="btn_prefix_sel" Content="Sel" Grid.Column="1" Width="36" Height="28" Margin="4,0,0,0" Style="{StaticResource SecondaryButton}" FontSize="11"/>
                                                    <Button x:Name="btn_prefix_all" Content="All" Grid.Column="2" Width="36" Height="28" Margin="4,0,0,0" Style="{StaticResource SecondaryButton}" FontSize="11"/>
                                                </Grid>

                                                <TextBlock Text="Suffix" FontSize="11" Foreground="#0F172A" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="tb_suffix" Grid.Column="0" Style="{StaticResource T3InputField}" Height="32"/>
                                                    <Button x:Name="btn_suffix_sel" Content="Sel" Grid.Column="1" Width="36" Height="28" Margin="4,0,0,0" Style="{StaticResource SecondaryButton}" FontSize="11"/>
                                                    <Button x:Name="btn_suffix_all" Content="All" Grid.Column="2" Width="36" Height="28" Margin="4,0,0,0" Style="{StaticResource SecondaryButton}" FontSize="11"/>
                                                </Grid>
                                                <Separator Background="#E2E8F0" Margin="0,0,0,12"/>

                                                <!-- Change Case -->
                                                <TextBlock Text="CHANGE CASE" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                                <ComboBox x:Name="cb_case_target" SelectedIndex="0" Style="{StaticResource T3ComboBox}" Height="36" Margin="0,0,0,8">
                                                    <ComboBoxItem Content="Both Family &amp; Type"/>
                                                    <ComboBoxItem Content="Family Name only"/>
                                                    <ComboBoxItem Content="Type Name only"/>
                                                </ComboBox>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button x:Name="btn_case_upper" Content="UPPER" Style="{StaticResource SecondaryButton}" Grid.Row="0" Grid.Column="0" Height="28" Margin="0,0,4,0" FontSize="11"/>
                                                    <Button x:Name="btn_case_lower" Content="lower" Style="{StaticResource SecondaryButton}" Grid.Row="0" Grid.Column="1" Height="28" Margin="4,0,0,0" FontSize="11"/>
                                                    <Button x:Name="btn_case_title" Content="Title" Style="{StaticResource SecondaryButton}" Grid.Row="2" Grid.Column="0" Height="28" Margin="0,0,4,0" FontSize="11"/>
                                                    <Button x:Name="btn_case_sentence" Content="Sentence" Style="{StaticResource SecondaryButton}" Grid.Row="2" Grid.Column="1" Height="28" Margin="4,0,0,0" FontSize="11"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </ScrollViewer>

                                    <!-- Sidebar Footer: Clear Button -->
                                    <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,8" Background="White">
                                        <Button x:Name="btn_clear_settings" Content="Clear All Settings" Style="{StaticResource SecondaryButton}" Height="28" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- RIGHT GRID CONTENT AREA -->
                            <Grid Grid.Column="1" Background="#F8FAFC">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="48"/>   <!-- Toolbar -->
                                    <RowDefinition Height="*"/>    <!-- DataGrid -->
                                    <RowDefinition Height="56"/>   <!-- Action Bar -->
                                </Grid.RowDefinitions>

                                <!-- TOOLBAR -->
                                <Grid Grid.Row="0" Background="White">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="260" Height="34" Margin="16,0,0,0"
                                            Background="White" BorderBrush="#DCDCE0" BorderThickness="1"
                                            CornerRadius="17" Padding="12,0,10,0" VerticalAlignment="Center">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="0" Data="M11 4 A7 7 0 1 0 11 18 A7 7 0 1 0 11 4 M21 21 L16.7 16.7"
                                                  Stroke="#71717A" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Grid Grid.Column="1">
                                                <TextBox x:Name="tb_search" BorderThickness="0" Background="Transparent"
                                                         VerticalContentAlignment="Center" VerticalAlignment="Center"
                                                         FontFamily="Hanken Grotesk" FontSize="13" Foreground="#27272A" Padding="0"/>
                                                <TextBlock Text="Search…" Foreground="#71717A" FontSize="13" FontFamily="Hanken Grotesk"
                                                           VerticalAlignment="Center" IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=tb_search}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                                        <Button x:Name="btn_export_list" Content="Export List" Height="28" Style="{StaticResource SecondaryButton}" Padding="10,2" FontSize="11"/>
                                    </StackPanel>
                                    <Border Height="1" VerticalAlignment="Bottom" Background="#E2E8F0" Grid.ColumnSpan="3"/>
                                </Grid>

                                <!-- DATAGRID -->
                                <Border Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Margin="16,12">
                                    <DataGrid x:Name="dg_families"
                                              AutoGenerateColumns="False" CanUserAddRows="False"
                                              Background="White" BorderThickness="0"
                                              AlternatingRowBackground="#F8FAFC" FontFamily="Inter" FontSize="12"
                                              Foreground="#27272A"
                                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#F1F5F9" SelectionMode="Extended"
                                              VerticalScrollBarVisibility="Auto">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background"      Value="#FFFFFF"/>
                                                <Setter Property="Foreground"      Value="#9A9AA2"/>
                                                <Setter Property="FontWeight"      Value="Bold"/>
                                                <Setter Property="FontSize"        Value="11"/>
                                                <Setter Property="Padding"         Value="8,6"/>
                                                <Setter Property="BorderBrush"     Value="#E2E8F0"/>
                                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                                <Setter Property="Height"          Value="34"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#E2E8F0"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="&#x2713;" Width="40">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Family Name" Binding="{Binding FamilyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTextColumn Header="Type Name" Binding="{Binding TypeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="150" IsReadOnly="True"/>
                                            <DataGridTemplateColumn Header="Workset" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Path=DataContext.Worksets}" SelectedValue="{Binding WorksetId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" SelectedValuePath="Id" FontFamily="Inter" FontSize="11" Padding="4,2" Height="24"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Action" Width="60">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Click="delete_row_click" Style="{StaticResource WinCtrlButton}" Width="28" Height="24" ToolTip="Remove from list" HorizontalAlignment="Center">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#EF4444"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                                <!-- ACTION BAR -->
                                <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,10">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Button x:Name="btn_select_all_mgmt" Content="Select All" Style="{StaticResource SecondaryButton}" Height="28" Margin="0,0,8,0"/>
                                            <Button x:Name="btn_deselect_all_mgmt" Content="Deselect All" Style="{StaticResource SecondaryButton}" Height="28"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button x:Name="btn_undo" Content="Undo" Style="{StaticResource SecondaryButton}" Width="80" Height="28" Margin="0,0,8,0"/>
                                            <Button x:Name="btn_apply" Content="Apply" Style="{StaticResource SuccessButton}" Width="100" Height="28"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
            </TabItem>
        </TabControl>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="© Copyright by T3Lab" FontSize="11" Foreground="#F59E0B" VerticalAlignment="Center"/>
                    <Border Width="1" Height="14" Background="#DCDCE0" Margin="12,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="status_text" FontSize="13.5" Foreground="#71717A" FontWeight="SemiBold" VerticalAlignment="Center" Text="Ready"/>
                </StackPanel>
                <TextBlock x:Name="count_text" Grid.Column="1" FontSize="11" Foreground="#64748B" VerticalAlignment="Center" Text="Total number of elements found 0 | Selected 0"/>
            </Grid>
        </Border>

    </Grid>


</Grid>
</Border>
</Window>
