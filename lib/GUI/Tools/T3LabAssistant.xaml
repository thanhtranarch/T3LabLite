        <!-- Chip button style (used for Quick Actions) -->
        <Style x:Key="T3ChipButton" TargetType="Button">
            <Setter Property="Background" Value="#E4E4E7"/>
            <Setter Property="Foreground" Value="#27272A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="chip_bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="12,5" BorderBrush="#D4D4D8" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.FontSize="11" TextBlock.FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#18181B"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="chip_bd" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    
    <Border BorderBrush="#A1A1AA" BorderThickness="1.5" CornerRadius="22" ClipToBounds="True" Background="#E4E4E7">
<Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- Header         -->
            <RowDefinition Height="1"/>    <!-- Separator      -->
            <RowDefinition Height="*"/>    <!-- Chat area      -->
            <RowDefinition Height="Auto"/> <!-- Command palette -->
            <RowDefinition Height="Auto"/> <!-- Input bar      -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             HEADER — T3Lab badge + title
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="#F4F4F6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <StackPanel Grid.Column="0" Orientation="Vertical"
                        Margin="22,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab Assistant" FontSize="15" FontWeight="Bold" Foreground="#18181B"/>
                </StackPanel>
            </StackPanel>

            <!-- Provider selector pill — always visible, shows active provider or "Set up AI" -->
            <Button x:Name="ai_status_badge"
                    Grid.Column="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Visibility="Visible"
                    Height="32" Padding="12,0,10,0"
                    Click="ai_badge_clicked"
                    Cursor="Hand"
                    ToolTip="Click to switch AI provider">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="pill"
                                CornerRadius="16"
                                Background="White"
                                BorderBrush="#E6E6EA"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" Direction="270" Color="#18181B" Opacity="0.06" BlurRadius="4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="pill" Property="BorderBrush" Value="#18181B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#F4F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ai_provider_dot" Width="8" Height="8" Fill="#A1A1AA" Margin="0,0,7,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ai_status_text"
                               Text="Set up AI"
                               FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"
                               Foreground="#27272A" VerticalAlignment="Center"/>
                    <Path Data="M0,0 L4,4 L8,0"
                          Stroke="#71717A" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="8" Height="5" Stretch="Uniform"
                          Margin="5,0,0,0" VerticalAlignment="Center"
                          IsHitTestVisible="False"/>
                </StackPanel>
            </Button>

            <!-- Window control buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,8,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Undo -->
                <Button x:Name="btn_undo"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Hoàn tác (Undo)"
                        Click="undo_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="↶" FontSize="18" FontWeight="Bold" Foreground="#F59E0B"/>
                </Button>
                <!-- Reset -->
                <Button x:Name="btn_reset_chat"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Làm mới cuộc trò chuyện"
                        Click="reset_chat_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="↺" FontSize="15" FontWeight="Bold" Foreground="#71717A"/>
                </Button>
                <!-- Settings sidebar toggle -->
                <Button x:Name="btn_settings"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="AI Settings"
                        Click="settings_btn_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                </Button>
                <!-- Minimize -->
                <Button x:Name="btn_minimize"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Minimize" Click="minimize_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                </Button>
                <!-- Maximize -->
                <Button x:Name="btn_maximize"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Maximize" Click="maximize_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                </Button>
                <!-- Close -->
                <Button x:Name="btn_close"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close" Click="close_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock x:Name="close_text" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Header separator -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#DCDCE0"/>

        <!-- ═══════════════════════════════════════════════════════════
             CHAT AREA
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Grid.Column="0">
            <ScrollViewer x:Name="chat_scroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#F4F4F6"
                          Padding="16,12,16,8">
                <StackPanel x:Name="chat_history_panel" Margin="0,0,0,4">

                    <!-- Dynamic Welcome Greeting -->
                    <Grid x:Name="welcome_greeting_panel" Margin="4,16,4,20" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="✳" FontSize="20" Foreground="#EA580C" FontWeight="Bold"
                                       FontFamily="Hanken Grotesk" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="welcome_greeting_text" Text="Good afternoon, Thạnh"
                                       FontSize="20" Foreground="#27272A" FontFamily="Georgia"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
            <ProgressBar x:Name="top_loading_bar" Height="2.5" Style="{StaticResource T3ProgressBar}" IsIndeterminate="True" Visibility="Collapsed" VerticalAlignment="Top"/>
        </Grid>


        <!-- ═══════════════════════════════════════════════════════════
             SETTINGS SIDEBAR — toggle with gear button
        ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="settings_sidebar"
                Grid.Row="2" Grid.Column="1"
                Width="240"
                Background="#F8FAFC"
                BorderBrush="#E6E6EA" BorderThickness="1,0,0,0"
                Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="14,16,14,20">

                    <!-- ── Profile summary card (Claude-style account header) ── -->
                    <Border Background="White" CornerRadius="12" Padding="12"
                            Margin="0,0,0,16" BorderBrush="#E6E6EA" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="20"
                                    Background="#18181B" VerticalAlignment="Center"
                                    Margin="0,0,11,0">
                                <TextBlock x:Name="sidebar_profile_initial" Text="T"
                                           Foreground="White" FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="sidebar_profile_name" Text="Thạnh"
                                           FontSize="13.5" FontWeight="SemiBold" Foreground="#18181B"/>
                                <TextBlock x:Name="sidebar_profile_sub" Text="T3Lab Assistant"
                                           FontSize="10.5" Foreground="#A1A1AA" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── User Profile ── -->
                    <TextBlock Text="DISPLAY NAME" FontSize="9" FontWeight="SemiBold"
                               Foreground="#A1A1AA" Margin="2,0,0,8"
                               FontFamily="Hanken Grotesk"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="sidebar_username_box" Grid.Column="0"
                                 Height="32" Margin="0,0,6,0"
                                 FontFamily="Hanken Grotesk" FontSize="12"
                                 Padding="10,0" BorderBrush="#E6E6EA"
                                 BorderThickness="1" Background="White"
                                 VerticalContentAlignment="Center"
                                 TextChanged="sidebar_username_changed"/>
                        <Button x:Name="sidebar_save_username_btn" Grid.Column="1"
                                Height="32" MinWidth="52" Cursor="Hand"
                                Click="sidebar_save_username_clicked"
                                ToolTip="Save user name">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="saveusr_bg" Background="#18181B"
                                            CornerRadius="8" Padding="10,0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="saveusr_bg" Property="Background" Value="#3F3F46"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="Save" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White" FontFamily="Hanken Grotesk"/>
                        </Button>
                    </Grid>

                    <Border Height="1" Background="#E6E6EA" Margin="0,0,0,14"/>

                    <!-- ── Provider ── -->
                    <TextBlock Text="PROVIDER" FontSize="9" FontWeight="SemiBold"
                               Foreground="#A1A1AA" Margin="2,0,0,8"
                               FontFamily="Hanken Grotesk"/>

                    <!-- Provider ComboBox with brand-color dot overlay -->
                    <Grid Margin="0,0,0,14">
                        <ComboBox x:Name="sidebar_provider_combo"
                                  Style="{StaticResource SidebarComboBox}"
                                  Padding="26,0,10,0"
                                  SelectionChanged="sidebar_provider_changed">
                            <ComboBoxItem Tag="claude">Claude (Anthropic)</ComboBoxItem>
                            <ComboBoxItem Tag="openai">GPT (OpenAI)</ComboBoxItem>
                            <ComboBoxItem Tag="deepseek">DeepSeek</ComboBoxItem>
                            <ComboBoxItem Tag="ollama">Local (Ollama)</ComboBoxItem>
                            <ComboBoxItem Tag="lmstudio">LM Studio</ComboBoxItem>
                        </ComboBox>
                        <!-- Brand color dot — updated from code when provider changes -->
                        <Ellipse x:Name="provider_brand_dot"
                                 Width="8" Height="8" Fill="#D97757"
                                 HorizontalAlignment="Left" VerticalAlignment="Center"
                                 Margin="12,0,0,0" IsHitTestVisible="False"/>
                    </Grid>

                    <Border Height="1" Background="#E6E6EA" Margin="0,0,0,14"/>

                    <!-- ── Model ── -->
                    <Grid Margin="2,0,0,8">
                        <TextBlock Text="MODEL" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#A1A1AA" FontFamily="Hanken Grotesk"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="model_saved_hint" Text=""
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="#10B981" FontFamily="Hanken Grotesk"/>
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="sidebar_model_combo" Grid.Column="0"
                                  Style="{StaticResource SidebarComboBox}"
                                  Margin="0,0,6,0"
                                  SelectionChanged="sidebar_model_changed"/>
                        <Button x:Name="sidebar_save_model_btn" Grid.Column="1"
                                Height="32" MinWidth="52" Cursor="Hand"
                                Click="sidebar_save_model_clicked"
                                ToolTip="Save selected model as default">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="savemdl_bg" Background="#18181B"
                                            CornerRadius="8" Padding="10,0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="savemdl_bg" Property="Background" Value="#3F3F46"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="savemdl_bg" Property="Background" Value="#E4E4E7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="Save" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White" FontFamily="Hanken Grotesk"/>
                        </Button>
                    </Grid>

                    <Border Height="1" Background="#E6E6EA" Margin="0,0,0,16"/>

                    <!-- ── API Key ── -->
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="API KEY" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#A1A1AA" VerticalAlignment="Center"
                                   Margin="2,0,0,0" FontFamily="Hanken Grotesk"/>
                        <Button x:Name="get_api_key_link" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Height="18" Cursor="Hand"
                                Click="get_api_key_clicked" ToolTip="Mở trang lấy API key">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="getkey_bg" Background="Transparent"
                                            CornerRadius="4" Padding="5,0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="getkey_bg" Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Lấy API key" FontSize="9.5" FontWeight="SemiBold"
                                           Foreground="#3B82F6" FontFamily="Hanken Grotesk"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                           Foreground="#3B82F6" Margin="3,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock x:Name="sidebar_key_label" Text="Anthropic API Key"
                               FontSize="11" Foreground="#71717A" Margin="2,0,0,6"
                               FontFamily="Hanken Grotesk"/>
                    <TextBox x:Name="sidebar_api_key_box"
                             Height="36" Margin="0,0,0,8"
                             FontFamily="Hanken Grotesk" FontSize="12"
                             Padding="10,0" BorderBrush="#E6E6EA"
                             BorderThickness="1" Background="White"
                             VerticalContentAlignment="Center"/>
                    <Button x:Name="sidebar_save_key_btn"
                            Height="34" Margin="0,0,0,16"
                            Cursor="Hand" Click="sidebar_save_key_clicked">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="save_bg" Background="#18181B"
                                        CornerRadius="10" Padding="12,0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="save_bg" Property="Background" Value="#3F3F46"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="save_bg" Property="Background" Value="#E4E4E7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="Save Key" FontSize="12" FontWeight="SemiBold"
                                   Foreground="White" FontFamily="Hanken Grotesk"/>
                    </Button>

                    <!-- ── Local Server Host (LM Studio / Ollama only) ── -->
                    <StackPanel x:Name="lmstudio_host_panel" Visibility="Collapsed" Margin="0,0,0,0">
                        <TextBlock Text="SERVER URL" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#A1A1AA" Margin="2,0,0,6"
                                   FontFamily="Hanken Grotesk"/>
                        <TextBlock x:Name="sidebar_host_label" Text="LM Studio base URL"
                                   FontSize="11" Foreground="#71717A" Margin="2,0,0,6"
                                   FontFamily="Hanken Grotesk"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="sidebar_host_box" Grid.Column="0"
                                     Height="32" Margin="0,0,6,0"
                                     FontFamily="Hanken Grotesk" FontSize="11"
                                     Padding="10,0" BorderBrush="#E6E6EA"
                                     BorderThickness="1" Background="White"
                                     VerticalContentAlignment="Center"
                                     Text="http://localhost:1234"/>
                            <Button x:Name="sidebar_save_host_btn" Grid.Column="1"
                                    Height="32" MinWidth="52" Cursor="Hand"
                                    Click="sidebar_save_host_clicked"
                                    ToolTip="Save server URL">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="savehost_bg" Background="#18181B"
                                                CornerRadius="8" Padding="10,0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="savehost_bg" Property="Background" Value="#3F3F46"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Save" FontSize="11" FontWeight="SemiBold"
                                           Foreground="White" FontFamily="Hanken Grotesk"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Border Height="1" Background="#E6E6EA" Margin="0,0,0,16"/>

                    <!-- ── Status ── -->
                    <TextBlock Text="STATUS" FontSize="9" FontWeight="SemiBold"
                               Foreground="#A1A1AA" Margin="2,0,0,10"
                               FontFamily="Hanken Grotesk"/>
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,6">
                        <Ellipse x:Name="status_dot_claude" Width="6" Height="6"
                                 Fill="#E6E6EA" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="Claude" FontSize="11" Foreground="#71717A"
                                   FontFamily="Hanken Grotesk" Width="52"/>
                        <TextBlock x:Name="status_text_claude" Text="—"
                                   FontSize="11" Foreground="#A1A1AA"
                                   FontFamily="Hanken Grotesk"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,6">
                        <Ellipse x:Name="status_dot_openai" Width="6" Height="6"
                                 Fill="#E6E6EA" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="OpenAI" FontSize="11" Foreground="#71717A"
                                   FontFamily="Hanken Grotesk" Width="52"/>
                        <TextBlock x:Name="status_text_openai" Text="—"
                                   FontSize="11" Foreground="#A1A1AA"
                                   FontFamily="Hanken Grotesk"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,6">
                        <Ellipse x:Name="status_dot_ollama" Width="6" Height="6"
                                 Fill="#E6E6EA" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="Ollama" FontSize="11" Foreground="#71717A"
                                   FontFamily="Hanken Grotesk" Width="52"/>
                        <TextBlock x:Name="status_text_ollama" Text="—"
                                   FontSize="11" Foreground="#A1A1AA"
                                   FontFamily="Hanken Grotesk"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,6">
                        <Ellipse x:Name="status_dot_lmstudio" Width="6" Height="6"
                                 Fill="#E6E6EA" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="LM Studio" FontSize="11" Foreground="#71717A"
                                   FontFamily="Hanken Grotesk" Width="52"/>
                        <TextBlock x:Name="status_text_lmstudio" Text="—"
                                   FontSize="11" Foreground="#A1A1AA"
                                   FontFamily="Hanken Grotesk"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                        <Ellipse x:Name="status_dot_deepseek" Width="6" Height="6"
                                 Fill="#E6E6EA" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="DeepSeek" FontSize="11" Foreground="#71717A"
                                   FontFamily="Hanken Grotesk" Width="52"/>
                        <TextBlock x:Name="status_text_deepseek" Text="—"
                                   FontSize="11" Foreground="#A1A1AA"
                                   FontFamily="Hanken Grotesk"/>
                    </StackPanel>

                    <!-- Test connection -->
                    <Border Height="1" Background="#E6E6EA" Margin="0,14,0,14"/>

                    <Button x:Name="sidebar_test_btn"
                            Height="32" Cursor="Hand"
                            Click="sidebar_test_clicked">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="test_bg" Background="#F4F4F6"
                                        CornerRadius="8" BorderBrush="#E6E6EA"
                                        BorderThickness="1" Padding="10,0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="test_bg" Property="Background" Value="#EBEBEF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="test_bg" Property="Background" Value="#F4F4F6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="#71717A"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Test Connection" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#52525B" FontFamily="Hanken Grotesk"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Test result -->
                    <Border x:Name="sidebar_test_result_border"
                            Visibility="Collapsed"
                            CornerRadius="8" Padding="10,8"
                            Margin="0,8,0,0"
                            Background="#F0FDF4"
                            BorderBrush="#BBF7D0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="sidebar_test_label"
                                       Text="Result" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#15803D" FontFamily="Hanken Grotesk"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="sidebar_test_result"
                                       Text="" TextWrapping="Wrap"
                                       FontSize="11" Foreground="#166534"
                                       FontFamily="Hanken Grotesk" LineHeight="16"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             COMMAND PALETTE (Row 3 — collapsible, above input bar)
        ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="cmd_palette"
                Grid.Row="3" Grid.ColumnSpan="2"
                Visibility="Collapsed"
                Background="White"
                BorderBrush="#E6E6EA" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header bar   -->
                    <RowDefinition Height="Auto"/>   <!-- Category tabs -->
                    <RowDefinition Height="230"/>    <!-- Command cards -->
                </Grid.RowDefinitions>

                <!-- ── Palette header ── -->
                <Border Grid.Row="0" Background="#F8FAFC"
                        BorderBrush="#E6E6EA" BorderThickness="0,0,0,1"
                        Padding="16,8,12,8">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Command Reference" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#27272A" FontFamily="Hanken Grotesk"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" — click any command to insert it" FontSize="11"
                                       Foreground="#A1A1AA" FontFamily="Hanken Grotesk"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="btn_cmd_palette_close"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Style="{StaticResource IconButton}"
                                Width="26" Height="26"
                                Click="cmd_palette_close_clicked">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="9" Foreground="#71717A"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── Category tabs ── -->
                <Border Grid.Row="1" Background="White"
                        BorderBrush="#E6E6EA" BorderThickness="0,0,0,1"
                        Padding="14,7,14,7">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btn_cat_export" Tag="export"
                                Click="cmd_cat_clicked" Cursor="Hand"
                                Height="27" Margin="0,0,6,0" Padding="12,3"
                                FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"
                                BorderThickness="0" Background="#18181B" Foreground="White">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE1DC;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Export" FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btn_cat_tools" Tag="tools"
                                Click="cmd_cat_clicked" Cursor="Hand"
                                Height="27" Margin="0,0,6,0" Padding="12,3"
                                FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"
                                BorderThickness="0" Background="#F4F4F6" Foreground="#27272A">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Tools" FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btn_cat_query" Tag="query"
                                Click="cmd_cat_clicked" Cursor="Hand"
                                Height="27" Margin="0,0,6,0" Padding="12,3"
                                FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"
                                BorderThickness="0" Background="#F4F4F6" Foreground="#27272A">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Query" FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btn_cat_create" Tag="create"
                                Click="cmd_cat_clicked" Cursor="Hand"
                                Height="27" Margin="0,0,6,0" Padding="12,3"
                                FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"
                                BorderThickness="0" Background="#F4F4F6" Foreground="#27272A">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE948;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Create" FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btn_cat_modify" Tag="modify"
                                Click="cmd_cat_clicked" Cursor="Hand"
                                Height="27" Margin="0,0,6,0" Padding="12,3"
                                FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"
                                BorderThickness="0" Background="#F4F4F6" Foreground="#27272A">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Modify" FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btn_cat_ai" Tag="ai"
                                Click="cmd_cat_clicked" Cursor="Hand"
                                Height="27" Padding="12,3"
                                FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"
                                BorderThickness="0" Background="#F4F4F6" Foreground="#27272A">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="AI Chat" FontFamily="Hanken Grotesk" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ── Command cards (WrapPanel, built from Python) ── -->
                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="cmd_cards_panel"
                               Orientation="Horizontal"
                               Margin="14,10,6,10"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             INPUT BAR & ACTION CENTER
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Grid.ColumnSpan="2" Background="#F4F4F6"
                BorderBrush="#DCDCE0" BorderThickness="0,1,0,0"
                Padding="16,8,16,10">
            <StackPanel>



                <!-- ── Attachment preview strip (hidden until files attached) ── -->

                <Border x:Name="attachment_preview_border"
                        Visibility="Collapsed"
                        Background="#F4F4F6"
                        BorderBrush="#E6E6EA" BorderThickness="1"
                        CornerRadius="3"
                        Padding="8,6"
                        Margin="0,0,0,6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="#27272A" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Đính kèm:" FontSize="10" FontWeight="Bold"
                                       Foreground="#27272A" VerticalAlignment="Center"/>
                            <Button x:Name="btn_clear_attachments"
                                    Style="{StaticResource IconButton}"
                                    Click="clear_attachments_clicked"
                                    ToolTip="Xóa tất cả đính kèm"
                                    Margin="6,0,0,0"
                                    Padding="3,1">
                                <TextBlock Text="✕ Xóa tất cả" FontSize="9" Foreground="#D23B3B"/>
                            </Button>
                        </StackPanel>
                        <WrapPanel x:Name="attachment_chips_panel"/>
                    </StackPanel>
                </Border>

                <!-- ── Input row ── -->
                <Border Height="42"
                        BorderBrush="#DCDCE0" BorderThickness="1"
                        CornerRadius="21" Background="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Attach button (locked) -->
                            <ColumnDefinition Width="*"/>     <!-- Text input -->
                            <ColumnDefinition Width="Auto"/>  <!-- Send button -->
                        </Grid.ColumnDefinitions>

                        <!-- Attach button (feature locked / disabled) -->
                        <Button Grid.Column="0" x:Name="btn_attach"
                                 Style="{StaticResource IconButton}"
                                 Width="36" Height="36"
                                 Margin="3,0,0,0"
                                 IsEnabled="False"
                                 Click="attach_clicked"
                                 ToolTip="Import file tạm khóa">
                            <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                        Foreground="#C4C4C8" VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                        </Button>

                        <!-- Text input -->
                        <TextBox Grid.Column="1" x:Name="chat_input"
                                  VerticalContentAlignment="Center"
                                  Padding="8,0"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  FontSize="13.5"
                                  Foreground="#18181B"
                                  CaretBrush="#18181B"
                                  ToolTip="Nhập lệnh Tiếng Việt hoặc English (Enter để gửi)"
                                  KeyDown="input_keydown"/>

                        <!-- Send button -->
                        <Button Grid.Column="2" x:Name="send_button"
                                 Style="{StaticResource PrimaryButton}"
                                 Height="36"
                                 Margin="0,0,3,0"
                                 Padding="16,0"
                                 Click="send_clicked"
                                 ToolTip="Gửi (Enter)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Gửi" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                            VerticalAlignment="Center" Margin="4,0,0,0" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
                <TextBlock Text="© Copyright by T3Lab" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="#F59E0B" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             FIRST-RUN ONBOARDING OVERLAY (shown only for new installs)
        ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="onboarding_overlay" Visibility="Collapsed"
                Grid.Row="0" Grid.RowSpan="99" Grid.Column="0" Grid.ColumnSpan="99"
                Panel.ZIndex="997" Background="#CC18181B">
            <Border Width="392" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="White" CornerRadius="16" Padding="28,26"
                    BorderBrush="#E6E6EA" BorderThickness="1">
                <StackPanel>
                    <!-- Brand row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="✳" FontSize="22" Foreground="#EA580C"
                                   FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,9,0"/>
                        <TextBlock Text="T3Lab Assistant" FontSize="13" FontWeight="Bold"
                                   Foreground="#18181B" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="onboarding_greeting" Text="Welcome 👋"
                               FontSize="24" FontWeight="Bold" Foreground="#18181B"
                               FontFamily="Georgia" Margin="0,6,0,2"/>
                    <TextBlock Text="Let's set up your profile so I can tailor things to you."
                               FontSize="12.5" Foreground="#71717A" TextWrapping="Wrap"
                               Margin="0,0,0,18"/>

                    <!-- Name -->
                    <TextBlock Text="YOUR NAME" FontSize="9" FontWeight="SemiBold"
                               Foreground="#A1A1AA" Margin="2,0,0,6"/>
                    <TextBox x:Name="onboarding_name_box" Height="38" FontSize="13"
                             Padding="11,0" BorderBrush="#CBD5E1" BorderThickness="1"
                             Background="White" VerticalContentAlignment="Center"
                             Margin="0,0,0,14"/>

                    <!-- Provider -->
                    <TextBlock Text="AI PROVIDER" FontSize="9" FontWeight="SemiBold"
                               Foreground="#A1A1AA" Margin="2,0,0,6"/>
                    <ComboBox x:Name="onboarding_provider_combo" Height="38" FontSize="13"
                              Padding="9,0" VerticalContentAlignment="Center"
                              Margin="0,0,0,14"
                              SelectionChanged="onboarding_provider_changed">
                        <ComboBoxItem Content="Claude — Anthropic" Tag="claude" IsSelected="True"/>
                        <ComboBoxItem Content="GPT — OpenAI" Tag="openai"/>
                        <ComboBoxItem Content="DeepSeek" Tag="deepseek"/>
                        <ComboBoxItem Content="Ollama — Local (no key)" Tag="ollama"/>
                        <ComboBoxItem Content="LM Studio — Local (no key)" Tag="lmstudio"/>
                    </ComboBox>

                    <!-- API key (hidden for local providers) -->
                    <StackPanel x:Name="onboarding_key_panel">
                        <TextBlock x:Name="onboarding_key_label" Text="API KEY"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="#A1A1AA" Margin="2,0,0,6"/>
                        <TextBox x:Name="onboarding_key_box" Height="38" FontSize="12"
                                 Padding="11,0" BorderBrush="#CBD5E1" BorderThickness="1"
                                 Background="White" VerticalContentAlignment="Center"
                                 Margin="0,0,0,4"/>
                        <TextBlock Text="Optional — you can add this later in Settings."
                                   FontSize="10.5" Foreground="#A1A1AA" Margin="2,0,0,16"/>
                    </StackPanel>

                    <!-- Actions -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Skip for now"
                                Style="{StaticResource SecondaryButton}" Height="38"
                                Padding="14,0" Click="onboarding_skip_clicked"/>
                        <Button Grid.Column="1" Content="Get started"
                                Style="{StaticResource PrimaryButton}" Height="38"
                                Padding="18,0" HorizontalAlignment="Right"
                                Click="onboarding_save_clicked"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
</Grid>

    </Border>

</Window>
