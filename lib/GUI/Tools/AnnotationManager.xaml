                                <Button x:Name="btn_txt_jump" Content="Jump to View" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="txt_jump" Width="120"/>
                                <Button Content="Delete Selected" Style="{StaticResource DangerButton}" Margin="0,0,8,0" Click="txt_delete" Width="120"/>
                                <Button Content="Select All" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="txt_select_all" Width="90"/>
                                <Button Content="Clear" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="txt_clear_sel" Width="70"/>
                                <Button x:Name="btn_txt_apply" Content="✔ Apply Changes" Style="{StaticResource PrimaryButton}" Visibility="Collapsed" Click="txt_apply" Width="130"/>
                            </StackPanel>
                            <TextBlock x:Name="txt_count" Text="0 found" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Auto-Rename Card -->
                        <Border Grid.Row="3" Background="{StaticResource BgLight}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="6" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Auto-Rename All Text Note Types" FontWeight="Bold" Foreground="{StaticResource TextDark}" FontSize="12"/>
                                    <TextBlock FontSize="10" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,4,0,0"
                                               Text="Generates: LB_[discipline]_[size]_[font]_[factor]_[bg]_[color]_[border]_[B/U/I]"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Rename All" Width="110" Style="{StaticResource OrangeButton}" Click="txt_rename_all" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- 3. DIMTEXT TAB (native inline) -->
            <TabItem>
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Scrollable content -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20,16,20,4">
                        <StackPanel>

                            <!-- TEXT FIELDS -->
                            <TextBlock Text="TEXT FIELDS" Style="{StaticResource DimSectionHeader}"/>
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Prefix" Style="{StaticResource DimFieldLabel}"/>
                                        <TextBox x:Name="txt_prefix" Style="{StaticResource DimInputBox}" Width="320"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Suffix" Style="{StaticResource DimFieldLabel}"/>
                                        <TextBox x:Name="txt_suffix" Style="{StaticResource DimInputBox}" Width="320"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Above" Style="{StaticResource DimFieldLabel}"/>
                                        <TextBox x:Name="txt_above" Style="{StaticResource DimInputBox}" Width="320"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Below" Style="{StaticResource DimFieldLabel}"/>
                                        <TextBox x:Name="txt_below" Style="{StaticResource DimInputBox}" Width="320"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Override" Style="{StaticResource DimFieldLabel}"/>
                                        <TextBox x:Name="txt_override" Style="{StaticResource DimInputBox}" Width="320"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- PRESETS — BELOW -->
                            <TextBlock Text="PRESETS — BELOW" Style="{StaticResource DimSectionHeader}"/>
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                                <WrapPanel x:Name="wrap_presets">
                                    <Button Content="CEILING HEIGHT" Style="{StaticResource DimPresetButton}" Tag="CEILING HEIGHT" Click="dimtext_preset_below"/>
                                    <Button Content="CLEAR"          Style="{StaticResource DimPresetButton}" Tag="CLEAR"          Click="dimtext_preset_below"/>
                                    <Button Content="V.I.F"          Style="{StaticResource DimPresetButton}" Tag="V.I.F"          Click="dimtext_preset_below"/>
                                    <Button Content="(E)"            Style="{StaticResource DimPresetButton}" Tag="(E)"            Click="dimtext_preset_below"/>
                                    <Button Content="M&amp;E SPACE"  Style="{StaticResource DimPresetButton}" Tag="M&amp;E SPACE"  Click="dimtext_preset_below"/>
                                    <Button Content="CANOPY TO SLAB" Style="{StaticResource DimPresetButton}" Tag="CANOPY TO SLAB" Click="dimtext_preset_below"/>
                                    <Button Content="CLEAR HEIGHT"   Style="{StaticResource DimPresetButton}" Tag="CLEAR HEIGHT"   Click="dimtext_preset_below"/>
                                </WrapPanel>
                            </Border>

                            <!-- OPTIONS -->
                            <TextBlock Text="OPTIONS" Style="{StaticResource DimSectionHeader}"/>
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <CheckBox x:Name="chk_leader" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="Turn off leader" FontSize="12" Foreground="#0F172A" FontWeight="SemiBold"/>
                                            <TextBlock Text="Removes leader lines from selected dimensions" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="Apply to:" FontSize="11" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="rb_selection" Content="Selection only" IsChecked="True"
                                                     FontSize="12" Foreground="#0F172A" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                        <RadioButton x:Name="rb_view" Content="All dims in active view"
                                                     FontSize="12" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- FILTER BY LENGTH -->
                            <TextBlock Text="FILTER BY LENGTH" Style="{StaticResource DimSectionHeader}"/>
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="chk_filter_enable" VerticalAlignment="Center" Margin="0,0,10,0"
                                                  Checked="dimtext_filter_toggle" Unchecked="dimtext_filter_toggle"/>
                                        <StackPanel>
                                            <TextBlock Text="Enable segment length filter" FontSize="12" Foreground="#0F172A" FontWeight="SemiBold"/>
                                            <TextBlock Text="Apply text only to segments matching the rules below" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel x:Name="sp_filter_config" Visibility="Collapsed" Margin="0,10,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <ComboBox x:Name="combo_combine" Width="230" Height="28" FontFamily="Hanken Grotesk" FontSize="12">
                                                <ComboBoxItem Content="AND — all rules must be true" IsSelected="True"/>
                                                <ComboBoxItem Content="OR — any rule may be true"/>
                                            </ComboBox>
                                            <Button x:Name="btn_add_rule" Content="+ Add Rule" Style="{StaticResource SecondaryButton}"
                                                    Click="dimtext_add_rule" Margin="8,0,0,0" Height="28" Padding="10,4"/>
                                        </StackPanel>
                                        <StackPanel x:Name="sp_rules"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- TIP -->
                            <Border BorderBrush="#E2E8F0" Background="#EFF6FF" CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Tip  " FontWeight="Bold" Foreground="#3B82F6" FontSize="11"/>
                                    <TextBlock FontSize="11" Foreground="#1E3A5F" TextWrapping="Wrap"
                                               Text="Leave all fields empty and click Apply to clear all text overrides on selected dimensions."/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Action bar -->
                    <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,10">
                        <Grid>
                            <Button x:Name="btn_clear_fields" Content="Clear Fields" HorizontalAlignment="Left"
                                    Style="{StaticResource SecondaryButton}" Click="dimtext_clear_fields"/>
                            <Button x:Name="btn_apply" Content="Apply" HorizontalAlignment="Right"
                                    Style="{StaticResource SuccessButton}" Click="dimtext_apply" MinWidth="100"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 5. UTILITIES TAB -->
            <TabItem>
                <Grid Background="White" Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>     <!-- Header -->
                        <RowDefinition Height="*"/>        <!-- Cards Grid -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="Annotation Utilities" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Helper tools for renumbering, case formatting, and document syncing" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Cards Row -->
                    <UniformGrid Grid.Row="1" Columns="3" VerticalAlignment="Top">
                        <!-- Card 1: Copy Annotation -->
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,16,0" Background="#F8FAFC">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Copy Annotations" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Transfer dimensions, text notes, tags, and detail components from this model to another open Revit document." 
                                               FontSize="11" Foreground="#64748B" TextWrapping="Wrap" Margin="0,6,0,16"/>
                                </StackPanel>
                                <Button Grid.Row="2" x:Name="btn_util_copy_anno" Style="{StaticResource PrimaryButton}" Height="36" Content="Launch Copier"/>
                            </Grid>
                        </Border>

                        <!-- Card 2: Renumber Along Spline -->
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,16,0" Background="#F8FAFC">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Renumber Along Spline" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Renumber any category of elements (such as doors, rooms, equipment) sequentially along a selected line/spline path." 
                                               FontSize="11" Foreground="#64748B" TextWrapping="Wrap" Margin="0,6,0,16"/>
                                </StackPanel>
                                <Button Grid.Row="2" x:Name="btn_util_renumber_spline" Style="{StaticResource PrimaryButton}" Height="36" Content="Start Renumbering"/>
                            </Grid>
                        </Border>

                        <!-- Card 3: Upper Case All -->
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16" Background="#F8FAFC">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Uppercase All Texts" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Convert view names, sheet names, title block parameter strings, text notes, and dimension overrides to UPPERCASE." 
                                               FontSize="11" Foreground="#64748B" TextWrapping="Wrap" Margin="0,6,0,16"/>
                                </StackPanel>
                                <Button Grid.Row="2" x:Name="btn_util_upper_all" Style="{StaticResource AccentButton}" Height="36" Content="Run Uppercase Converter"/>
                            </Grid>
                        </Border>
                    </UniformGrid>
                </Grid>
            </TabItem>

            <!-- 6. SETTINGS TAB -->
            <TabItem>
                <Grid Margin="24,24,24,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Card: General Preferences -->
                    <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="General Preferences" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}"/>
                                <TextBlock Text="Configure behavior settings for Annotation Manager" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Setting Toggles -->
                            <CheckBox Grid.Row="2" Content="Auto-select matching elements in view when clicking row" FontSize="13" Foreground="{StaticResource TextDark}" IsChecked="True"/>
                            <CheckBox Grid.Row="4" Content="Include annotations inside groups in search results" FontSize="13" Foreground="{StaticResource TextDark}" IsChecked="False"/>
                            <CheckBox Grid.Row="6" Content="Prompt for confirmation before batch deleting elements" FontSize="13" Foreground="{StaticResource TextDark}" IsChecked="True"/>
                        </Grid>
                    </Border>

                    <!-- Right Card: About & Info -->
                    <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="About T3Lab Annotation Suite" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}"/>
                                <TextBlock Text="Unified management for Revit drafting elements" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Branding Details -->
                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Annotation Manager" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                                <TextBlock Text="Version 1.0.1" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                <TextBlock Text="Author: Tran Tien Thanh" FontSize="12" Foreground="{StaticResource TextDark}" Margin="0,8,0,0"/>
                                <TextBlock Text="Contact: trantienthanh909@gmail.com" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>

                            <!-- Info Box -->
                            <Border Grid.Row="4" Background="{StaticResource LightBlueHighlight}" CornerRadius="6" Padding="12">
                                <TextBlock Text="This utility combines multiple annotation control panels into a unified tool, optimizing your Revit models by standardizing text, cleaning unused styles, and offering rapid auto-renaming of DimensionTypes and TextNoteTypes based on physical parameters."
                                           TextWrapping="Wrap" FontSize="12" LineHeight="18" Foreground="{StaticResource PrimaryBlue}"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══ FOOTER STATUS BAR ═══ -->
        <Border Grid.Row="2" Grid.Column="1" Background="#F4F4F6" BorderBrush="#DCDCE0" BorderThickness="0,1,0,0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="© Copyright by T3Lab" FontSize="11" Foreground="#F59E0B" VerticalAlignment="Center"/>
                    <Border Width="1" Height="14" Background="#DCDCE0" Margin="12,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="status" FontSize="13.5" Foreground="#71717A" FontWeight="SemiBold" Text="Ready." VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
</Grid>

    </Border>

</Window>
